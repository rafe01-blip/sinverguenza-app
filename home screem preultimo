  const [weather, setWeather] = useState<WeatherState>({
    temp: 72,
    label: "Clear",
    icon: "sun",
    cityLabel: user?.city || "New York",
  })

  useEffect(() => {
    let mounted = true

    async function loadWeather() {
      try {
        const hasGeo = typeof navigator !== "undefined" && navigator.geolocation

        if (hasGeo) {
          navigator.geolocation.getCurrentPosition(
            async (position) => {
              try {
                const { latitude, longitude } = position.coords
                const weatherRes = await fetch(
                  `https://api.open-meteo.com/v1/forecast?latitude=${latitude}&longitude=${longitude}&current=temperature_2m,weather_code&temperature_unit=fahrenheit`
                )
                const weatherData = await weatherRes.json()

                if (!mounted) return

                const temp = Math.round(weatherData?.current?.temperature_2m ?? 72)
                const code = weatherData?.current?.weather_code ?? 1

                setWeather({
                  temp,
                  label: getWeatherLabel(code),
                  icon: getWeatherIcon(code),
                  cityLabel: user?.city || "New York",
                })
              } catch {
                if (!mounted) return
                setWeather((prev) => ({
                  ...prev,
                  cityLabel: user?.city || "New York",
                }))
              }
            },
            async () => {
              try {
                const res = await fetch(
                  "https://api.open-meteo.com/v1/forecast?latitude=40.7128&longitude=-74.0060&current=temperature_2m,weather_code&temperature_unit=fahrenheit"
                )
                const data = await res.json()

                if (!mounted) return

                const temp = Math.round(data?.current?.temperature_2m ?? 72)
                const code = data?.current?.weather_code ?? 1

                setWeather({
                  temp,
                  label: getWeatherLabel(code),
                  icon: getWeatherIcon(code),
                  cityLabel: user?.city || "New York",
                })
              } catch {
                if (!mounted) return
                setWeather({
                  temp: 72,
                  label: "Clear",
                  icon: "sun",
                  cityLabel: user?.city || "New York",
                })
              }
            }
          )
          return
        }

        const res = await fetch(
          "https://api.open-meteo.com/v1/forecast?latitude=40.7128&longitude=-74.0060&current=temperature_2m,weather_code&temperature_unit=fahrenheit"
        )
        const data = await res.json()

        if (!mounted) return

        const temp = Math.round(data?.current?.temperature_2m ?? 72)
        const code = data?.current?.weather_code ?? 1

        setWeather({
          temp,
          label: getWeatherLabel(code),
          icon: getWeatherIcon(code),
          cityLabel: user?.city || "New York",
        })
      } catch {
        if (!mounted) return
        setWeather({
          temp: 72,
