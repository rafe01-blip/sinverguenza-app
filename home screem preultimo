function PinnedArea({
  pinnedEvents,
  openPinnedCalendarFocus,
}: {
  pinnedEvents: EventType[]
  openPinnedCalendarFocus: () => void
}) {
  if (pinnedEvents.length === 0) return null

  const firstPinned = pinnedEvents[0]

  const metaLabel =
    pinnedEvents.length === 1
      ? `${new Date(`${firstPinned.date}T00:00:00`).toLocaleDateString("en-US", {
          weekday: "short",
          month: "short",
          day: "numeric",
        })} • ${formatTime12h(firstPinned.time || "10:00")} • ${firstPinned.location || "Location"}`
      : `${pinnedEvents.length} events pinned →`

  return (
    <div className="px-4 pt-3">
      <button
        onClick={openPinnedCalendarFocus}
        className="group flex w-full items-center justify-between gap-3 rounded-[22px] border border-primary/25 bg-primary/10 px-4 py-3 text-left shadow-[0_0_18px_rgba(201,168,76,0.12)] transition-all active:scale-[0.99]"
