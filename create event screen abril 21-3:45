                  <Label className="text-foreground flex items-center gap-2">
                    <Clock className="h-4 w-4 text-primary" />
                    Start Time *
                  </Label>
                  <Input
                    type="time"
                    value={formData.time}
                    onChange={(e) => updateField("time", e.target.value)}
                    required
                    className="h-11 bg-background border-border"
                  />
                </div>
              </div>

              <div className="space-y-2">
                <Label className="text-foreground flex items-center gap-2">
                  <Clock className="h-4 w-4 text-primary" />
                  End Time (optional)
                </Label>
                <Input
                  type="time"
                  value={formData.endTime}
                  onChange={(e) => updateField("endTime", e.target.value)}
                  className="h-11 bg-background border-border"
                />
              </div>

              <div className="space-y-2">
                <Label className="text-foreground flex items-center gap-2">
                  <MapPin className="h-4 w-4 text-primary" />
                  Location
                </Label>
                <Input
                  placeholder="Location or venue"
                  value={formData.location}
                  onChange={(e) => updateField("location", e.target.value)}
                  className="h-11 bg-background border-border"
                />
              </div>

              <div className="space-y-2">
                <Label className="text-foreground flex items-center gap-2">
                  <Link2 className="h-4 w-4 text-primary" />
                  Online Link (optional)
                </Label>
                <Input
                  placeholder="Zoom, Google Meet, Instagram Live..."
                  value={formData.onlineLink}
                  onChange={(e) => updateField("onlineLink", e.target.value)}
                  className="h-11 bg-background border-border"
                />
              </div>

              <div className="space-y-2">
                <Label className="text-foreground">Category</Label>
                <div className="grid grid-cols-3 gap-2">
                  {CATEGORY_OPTIONS.map((cat) => (
                    <button
                      key={cat.value}
                      type="button"
                      onClick={() => updateField("category", cat.value || "event")}
                      className={`p-3 rounded-xl border-2 transition-all text-sm ${
                        formData.category === cat.value
                          ? "border-primary bg-primary/10 text-primary"
                          : "border-border bg-background text-muted-foreground hover:border-primary/50"
                      }`}
                    >
                      {cat.label}
                    </button>
                  ))}
                </div>
              </div>

              <div className="space-y-2">
                <Label className="text-foreground">Activity Type</Label>
                <div className="flex flex-wrap gap-2">
                  {ACTIVITY_OPTIONS.map((option) => {
                    const active = activityTypes.includes(option.slug)
                    return (
                      <button
                        key={option.slug}
                        type="button"
                        onClick={() => toggleActivityType(option.slug)}
                        className={`px-3 py-2 rounded-full text-sm font-medium border transition-colors ${
                          active
                            ? "bg-primary text-primary-foreground border-primary"
                            : "bg-background text-foreground border-border hover:bg-secondary"
                        }`}
                      >
                        {option.label}
                      </button>
                    )
                  })}
                </div>
              </div>
            </div>
            <div className="rounded-[24px] border border-border bg-card p-4 space-y-4 shadow-[0_14px_32px_rgba(0,0,0,0.10)]">
              <div className="space-y-2">
                <Label className="text-foreground">Pricing</Label>

                <div className="grid grid-cols-2 gap-3">
                  <button
                    type="button"
                    onClick={() => {
                      updateField("isFree", true)
                      updateField("price", "")
                      updateField("paymentMethod", "")
                      updateField("zelleContact", "")
                    }}
                    className={`p-4 rounded-xl border-2 transition-all flex items-center gap-3 ${
                      formData.isFree
                        ? "border-primary bg-primary/10"
                        : "border-border bg-background hover:border-primary/50"
                    }`}
                  >
                    <Gift className={`h-5 w-5 ${formData.isFree ? "text-primary" : "text-muted-foreground"}`} />
                    <div className="text-left">
                      <p className={`font-medium ${formData.isFree ? "text-primary" : "text-foreground"}`}>
                        Free
                      </p>
                      <p className="text-xs text-muted-foreground">No charge</p>
                    </div>
                  </button>

                  <button
                    type="button"
                    onClick={() => updateField("isFree", false)}
                    className={`p-4 rounded-xl border-2 transition-all flex items-center gap-3 ${
                      !formData.isFree
                        ? "border-primary bg-primary/10"
                        : "border-border bg-background hover:border-primary/50"
                    }`}
                  >
                    <DollarSign className={`h-5 w-5 ${!formData.isFree ? "text-primary" : "text-muted-foreground"}`} />
                    <div className="text-left">
                      <p className={`font-medium ${!formData.isFree ? "text-primary" : "text-foreground"}`}>
                        Paid
                      </p>
                      <p className="text-xs text-muted-foreground">Set a price</p>
                    </div>
                  </button>
                </div>

                {!formData.isFree && (
                  <div className="space-y-3 mt-3">
                    <div className="relative">
                      <span className="absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground">$</span>
                      <Input
                        type="number"
                        placeholder="0.00"
                        value={formData.price}
                        onChange={(e) => updateField("price", e.target.value)}
                        className="h-11 bg-background border-border pl-8"
                        min="0"
                        step="0.01"
                      />
                    </div>

                    <div className="space-y-2">
                      <Label className="text-foreground flex items-center gap-2">
                        <BadgeDollarSign className="h-4 w-4 text-primary" />
                        Payment Method
                      </Label>
                      <div className="grid grid-cols-2 gap-3">
                        {PAYMENT_OPTIONS.map((method) => (
                          <button
                            key={method}
                            type="button"
                            onClick={() => updateField("paymentMethod", method)}
                            className={`p-3 rounded-xl border-2 transition-all text-left ${
                              formData.paymentMethod === method
                                ? "border-primary bg-primary/10"
                                : "border-border bg-background hover:border-primary/50"
                            }`}
                          >
                            <p className={`font-medium ${formData.paymentMethod === method ? "text-primary" : "text-foreground"}`}>
                              {method}
                            </p>
                          </button>
                        ))}
                      </div>
                    </div>

                    {formData.paymentMethod === "Zelle" && (
                      <div className="space-y-2">
                        <Label className="text-foreground">Zelle Email or Phone</Label>
                        <Input
                          placeholder="Enter Zelle email or phone"
                          value={formData.zelleContact}
                          onChange={(e) => updateField("zelleContact", e.target.value)}
                          className="h-11 bg-background border-border"
                        />
                      </div>
                    )}
                  </div>
                )}
              </div>

              <div className="space-y-2">
                <Label className="text-foreground">Visibility</Label>

                <div className="grid grid-cols-2 gap-3">
                  <button
                    type="button"
                    onClick={() => updateField("type", "public")}
                    className={`p-4 rounded-xl border-2 transition-all flex items-center gap-3 ${
                      formData.type === "public"
                        ? "border-primary bg-primary/10"
                        : "border-border bg-background hover:border-primary/50"
                    }`}
                  >
                    <Globe className={`h-5 w-5 ${formData.type === "public" ? "text-primary" : "text-muted-foreground"}`} />
                    <div className="text-left">
                      <p className={`font-medium ${formData.type === "public" ? "text-primary" : "text-foreground"}`}>
                        Public
                      </p>
                      <p className="text-xs text-muted-foreground">Everyone can see</p>
                    </div>
                  </button>

                  <button
                    type="button"
                    onClick={() => updateField("type", "private")}
                    className={`p-4 rounded-xl border-2 transition-all flex items-center gap-3 ${
                      formData.type === "private"
                        ? "border-primary bg-primary/10"
                        : "border-border bg-background hover:border-primary/50"
                    }`}
                  >
                    <Lock className={`h-5 w-5 ${formData.type === "private" ? "text-primary" : "text-muted-foreground"}`} />
                    <div className="text-left">
                      <p className={`font-medium ${formData.type === "private" ? "text-primary" : "text-foreground"}`}>
                        Private
                      </p>
                      <p className="text-xs text-muted-foreground">Invite only</p>
                    </div>
                  </button>
                </div>

                {formData.type === "private" && (
                  <div className="mt-3 rounded-2xl border border-border bg-background p-4 space-y-3">
                    <div className="flex items-center gap-2">
                      <Users className="h-4 w-4 text-primary" />
                      <Label className="text-foreground">Guest Limit</Label>
                    </div>

                    <div className="grid grid-cols-2 gap-3">
                      <button
                        type="button"
                        onClick={() => updateField("guestLimitEnabled", false)}
                        className={`p-3 rounded-xl border-2 text-sm ${
                          !formData.guestLimitEnabled
                            ? "border-primary bg-primary/10 text-primary"
                            : "border-border bg-card text-foreground"
                        }`}
                      >
                        No limit
                      </button>

                      <button
                        type="button"
                        onClick={() => updateField("guestLimitEnabled", true)}
                        className={`p-3 rounded-xl border-2 text-sm ${
                          formData.guestLimitEnabled
                            ? "border-primary bg-primary/10 text-primary"
                            : "border-border bg-card text-foreground"
                        }`}
                      >
                        Set limit
                      </button>
                    </div>

                    {formData.guestLimitEnabled && (
                      <Input
                        type="number"
                        min="1"
                        placeholder="Max number of guests"
                        value={formData.guestLimit}
                        onChange={(e) => updateField("guestLimit", e.target.value)}
                        className="h-11 bg-card border-border"
                      />
                    )}
                  </div>
                )}
              </div>

              <div className="space-y-2">
                <Label className="text-foreground flex items-center gap-2">
                  <ShieldCheck className="h-4 w-4 text-primary" />
                  Age Rule
                </Label>

                <div className="grid grid-cols-3 gap-2">
                  {AGE_RULE_OPTIONS.map((option) => {
                    const active = formData.ageRule === option
                    return (
                      <button
                        key={option}
                        type="button"
                        onClick={() => updateField("ageRule", option)}
                        className={`p-3 rounded-xl border-2 transition-all text-sm ${
                          active
                            ? "border-primary bg-primary/10 text-primary"
                            : "border-border bg-background text-muted-foreground hover:border-primary/50"
                        }`}
                      >
                        {option === "family" ? "Family" : option}
                      </button>
                    )
                  })}
                </div>
              </div>

              <div className="space-y-2">
                <Label className="text-foreground flex items-center gap-2">
                  <Phone className="h-4 w-4 text-primary" />
                  Contact Phone (optional)
                </Label>
                <Input
                  placeholder="Phone or WhatsApp number"
                  value={formData.phoneNumber}
                  onChange={(e) => updateField("phoneNumber", e.target.value)}
                  className="h-11 bg-background border-border"
                />
              </div>

              <div className="space-y-2">
                <Label className="text-foreground flex items-center gap-2">
                  <FileText className="h-4 w-4 text-primary" />
                  Special Instructions (optional)
                </Label>
                <Textarea
                  value={formData.specialInstructions}
                  onChange={(e) => updateField("specialInstructions", e.target.value)}
                  rows={3}
                  placeholder="Bring ID, DM after payment, doors close at 9 PM..."
                  className="bg-background border-border resize-none"
                />
              </div>

                            <div className="space-y-2">
                <Label className="text-foreground">Status</Label>
                <div className="grid grid-cols-2 gap-2">
                  {STATUS_OPTIONS.map((status) => {
                    const active = formData.status === status.value
                    return (
                      <button
                        key={status.value}
                        type="button"
                        onClick={() => updateField("status", status.value)}
                        className={`p-3 rounded-xl border-2 transition-all text-sm ${
                          active
                            ? "border-primary bg-primary/10 text-primary"
                            : "border-border bg-background text-muted-foreground hover:border-primary/50"
                        }`}
                      >
                        {status.label}
                      </button>
                    )
                  })}
                </div>
              </div>
            </div>
          </div>
        </div>

        <div className="h-28" />
      </form>

      {/* 👇 BOTÓN FIJO PREMIUM */}
      <div className="fixed bottom-[88px] left-0 right-0 z-40 px-4">
        <div className="mx-auto max-w-[520px] rounded-[24px] border border-border bg-background/90 backdrop-blur-md p-3 shadow-[0_12px_30px_rgba(0,0,0,0.22)]">
          <Button
  type="submit"
  form="create-event-form"
  className="w-full h-14 rounded-2xl bg-primary text-primary-foreground hover:bg-primary/90 text-base font-medium shadow-[0_10px_30px_rgba(201,168,76,0.18)] active:scale-[0.98] transition-all"
  disabled={isSubmitting}
>
  {isSubmitting ? (
    <span className="flex items-center gap-2">
      <span className="h-4 w-4 border-2 border-primary-foreground/30 border-t-primary-foreground rounded-full animate-spin" />
      Creating event...
    </span>
  ) : (
    <>
      <Plus className="mr-2 h-5 w-5" />
      Create Event
    </>
  )}
</Button>
        </div>
      </div>

      <BottomNav />
    </div>
  )
}

             