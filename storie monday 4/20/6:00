"use client"

import { useEffect, useMemo, useState } from "react"
import {
  ChevronLeft,
  ChevronRight,
  Heart,
  Instagram,
  MessageCircle,
  Send,
  X,
} from "lucide-react"
import { useApp, StoryReaction } from "@/lib/app-context"

const GOLD = "#C9A84C"

const STORY_REACTIONS: StoryReaction[] = ["❤️", "🔥", "👏", "🕺🏾", "💃", "😎", "🤣"]

function timeAgoFromDate(dateString: string) {
  const now = Date.now()
  const then = new Date(dateString).getTime()
  const diff = Math.max(1, now - then)

  const minutes = Math.floor(diff / (1000 * 60))
  const hours = Math.floor(diff / (1000 * 60 * 60))
  const days = Math.floor(diff / (1000 * 60 * 60 * 24))

  if (minutes < 60) return `${minutes}m ago`
  if (hours < 24) return `${hours}h ago`
  return `${days}d ago`
}

function getStoryModeLabel(source: "home" | "community" | null) {
  if (source === "home") return "From Home"
  if (source === "community") return "From Community"
  return "Story"
}
export function StoryViewerScreen() {
  const {
    creators,
    user,
    selectedStoryId,
    setSelectedStoryId,
    setCurrentScreen,
    storySource,
    getStoriesForSource,
    markStorySeen,
    toggleStoryLike,
    addStoryReply,
    setStoryReaction,
  } = useApp()

  const availableStories = useMemo(() => {
    if (!storySource) return []
    return getStoriesForSource(storySource)
  }, [getStoriesForSource, storySource])

  const initialIndex = useMemo(() => {
    if (!selectedStoryId) return 0
    const index = availableStories.findIndex((story) => story.id === selectedStoryId)
    return index >= 0 ? index : 0
  }, [availableStories, selectedStoryId])

  const [activeIndex, setActiveIndex] = useState(initialIndex)
  const [activeSlideIndex, setActiveSlideIndex] = useState(0)
  const [replyText, setReplyText] = useState("")
  const [progressKey, setProgressKey] = useState(0)

  useEffect(() => {
    setActiveIndex(initialIndex)
    setActiveSlideIndex(0)
    setProgressKey((prev) => prev + 1)
  }, [initialIndex])

  const activeStory = availableStories[activeIndex]

  const activeCreator = useMemo(() => {
    if (!activeStory) return null
    return creators.find((creator) => creator.id === activeStory.authorId) || null
  }, [activeStory, creators])

  const activeSlides = activeStory?.slides ?? []
  const activeSlide =
    activeSlides[activeSlideIndex] || activeSlides[0] || null

  useEffect(() => {
    if (!activeStory) return
    markStorySeen(activeStory.id)
  }, [activeStory, markStorySeen])

  useEffect(() => {
    if (!activeStory) return
    setProgressKey((prev) => prev + 1)

    const timer = window.setTimeout(() => {
      if (activeSlideIndex < activeSlides.length - 1) {
        setActiveSlideIndex((prev) => prev + 1)
        return
      }

      if (activeIndex < availableStories.length - 1) {
        setActiveIndex((prev) => prev + 1)
        setActiveSlideIndex(0)
        return
      }

      handleClose()
    }, 4500)

    return () => window.clearTimeout(timer)
  }, [activeIndex, activeSlideIndex, activeSlides.length, activeStory, availableStories.length])
  const handleClose = () => {
    setSelectedStoryId(null)
    setCurrentScreen(storySource === "home" ? "home" : "community")
  }

  const handlePrevious = () => {
    if (!activeStory) return

    if (activeSlideIndex > 0) {
      setActiveSlideIndex((prev) => prev - 1)
      return
    }

    if (activeIndex > 0) {
      const previousStory = availableStories[activeIndex - 1]
      const previousLastSlideIndex = Math.max(0, (previousStory?.slides?.length ?? 1) - 1)
      setActiveIndex((prev) => prev - 1)
      setActiveSlideIndex(previousLastSlideIndex)
      return
    }
  }

  const handleNext = () => {
    if (!activeStory) return

    if (activeSlideIndex < activeSlides.length - 1) {
      setActiveSlideIndex((prev) => prev + 1)
      return
    }

    if (activeIndex < availableStories.length - 1) {
      setActiveIndex((prev) => prev + 1)
      setActiveSlideIndex(0)
      return
    }

    handleClose()
  }

  const openInstagram = () => {
    const url = activeStory?.instagramUrl || activeCreator?.instagramUrl || activeCreator?.socials?.instagram
    if (!url || typeof window === "undefined") return
    window.open(url, "_blank", "noopener,noreferrer")
  }

  const submitReply = () => {
    const trimmed = replyText.trim()
    if (!trimmed || !activeStory) return
    addStoryReply(activeStory.id, trimmed)
    setReplyText("")
  }

  const showReplyInput = storySource === "home"
  const storyImage =
    activeSlide?.image ||
    activeStory?.image ||
    activeCreator?.coverImage ||
    activeCreator?.avatar ||
    "/placeholder.svg"

  if (!activeStory || !activeCreator || !activeSlide) {
    return null
  }
  return (
    <div className="fixed inset-0 z-[100] overflow-hidden bg-black">
      <div className="absolute inset-0">
        <img
          src={storyImage}
          alt={activeStory.content}
          className="h-full w-full object-cover"
        />
      </div>

      <div className="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.38)_0%,rgba(0,0,0,0.08)_35%,rgba(0,0,0,0.72)_100%)]" />

      <div className="absolute left-3 right-3 top-3 z-[5] flex gap-1.5">
        {activeSlides.map((slide, index) => (
          <div
            key={slide.id}
            className="relative h-1.5 flex-1 overflow-hidden rounded-full bg-white/25"
          >
            {index < activeSlideIndex && <div className="h-full w-full rounded-full bg-white" />}

            {index === activeSlideIndex && (
              <div
                key={`${slide.id}-${progressKey}`}
                className="story-progress h-full rounded-full bg-white"
              />
            )}
          </div>
        ))}
      </div>

      <div className="absolute left-4 right-4 top-7 z-[6] flex items-center justify-between gap-3">
        <div className="flex min-w-0 items-center gap-3">
          <button onClick={handleClose} className={circleBtnClass}>
            <X className="h-5 w-5" />
          </button>

          <div className="relative h-12 w-12 overflow-hidden rounded-full border-[2.5px] border-primary bg-zinc-800">
            <img
              src={activeCreator.avatar || "/placeholder.svg"}
              alt={activeCreator.name}
              className="h-full w-full object-cover"
            />
          </div>

          <div className="min-w-0">
            <div className="truncate text-[15px] font-semibold text-white">
              {activeCreator.displayName || activeCreator.name}
            </div>

            <button
              onClick={openInstagram}
              disabled={
                !(
                  activeStory.instagramUrl ||
                  activeCreator.instagramUrl ||
                  activeCreator.socials?.instagram
                )
              }
              className="inline-flex items-center gap-1 truncate text-[13px] text-zinc-200 disabled:opacity-80"
            >
              <span>@{activeCreator.username}</span>
              {(activeStory.instagramUrl ||
                activeCreator.instagramUrl ||
                activeCreator.socials?.instagram) && (
                <Instagram className="h-3.5 w-3.5 text-primary" />
              )}
            </button>
          </div>
        </div>

        <div className="rounded-full border border-white/10 bg-black/40 px-3 py-1.5 text-[10px] font-semibold uppercase tracking-[0.18em] text-primary backdrop-blur-md">
          {getStoryModeLabel(storySource)}
        </div>
      </div>
      {availableStories.length > 1 && (
        <>
          <button
            onClick={handlePrevious}
            className="absolute left-0 top-0 z-[3] h-full w-1/2"
            aria-label="Previous story"
          />
          <button
            onClick={handleNext}
            className="absolute right-0 top-0 z-[3] h-full w-1/2"
            aria-label="Next story"
          />

          <button onClick={handlePrevious} className={`${navBtnClass} left-4`}>
            <ChevronLeft className="h-7 w-7" />
          </button>

          <button onClick={handleNext} className={`${navBtnClass} right-4`}>
            <ChevronRight className="h-7 w-7" />
          </button>
        </>
      )}

      <div className="absolute bottom-5 left-4 right-4 z-[6]">
        <div className="rounded-[28px] border border-white/10 bg-[rgba(16,16,16,0.82)] p-4 backdrop-blur-xl shadow-[0_16px_42px_rgba(0,0,0,0.34)]">
          <div className="mb-3 flex flex-wrap items-center gap-2">
            <span className="rounded-full border border-primary/30 bg-primary/12 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-primary">
              {activeStory.type === "video" ? "Video Story" : "Story"}
            </span>

            <span className="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-zinc-300">
              Slide {activeSlideIndex + 1}/{Math.max(1, activeSlides.length)}
            </span>

            <span className="text-[12px] text-zinc-400">
              {timeAgoFromDate(activeStory.createdAt)}
            </span>
          </div>

          <h2 className="mb-2 text-[22px] font-bold leading-tight text-white">
            {activeSlide.content || activeStory.content}
          </h2>

          <p className="mb-4 text-[14px] leading-6 text-zinc-300">
            {storySource === "home"
              ? "Private social feel for people you follow, with replies enabled."
              : "Global community story with premium public card presentation and quick reactions."}
          </p>

          <div className="mb-4 flex flex-wrap items-center gap-2">
            <button
              onClick={() => toggleStoryLike(activeStory.id)}
              className={`inline-flex items-center gap-2 rounded-full border px-3.5 py-2 text-sm font-medium transition-colors ${
                activeStory.isLiked
                  ? "border-red-500/30 bg-red-500/12 text-red-400"
                  : "border-white/10 bg-white/[0.04] text-zinc-200"
              }`}
            >
              <Heart className={`h-4 w-4 ${activeStory.isLiked ? "fill-red-500" : ""}`} />
              {activeStory.likesCount ?? 0}
            </button>

            {STORY_REACTIONS.map((reaction) => (
              <button
                key={reaction}
                onClick={() => setStoryReaction(activeStory.id, reaction)}
                className={`flex h-9 w-9 items-center justify-center rounded-full border text-[16px] transition-colors ${
                  activeStory.myReaction === reaction
                    ? "border-primary bg-primary/15"
                    : "border-white/10 bg-white/[0.04]"
                }`}
              >
                {reaction}
              </button>
            ))}
          </div>
          <div className="mb-3 flex items-center justify-between gap-3 text-[12px] text-zinc-400">
            <span>{activeStory.replies?.length ?? 0} replies</span>

            {(activeStory.instagramUrl ||
              activeCreator.instagramUrl ||
              activeCreator.socials?.instagram) && (
              <button
                onClick={openInstagram}
                className="inline-flex items-center gap-1.5 text-primary"
              >
                <Instagram className="h-4 w-4" />
                Open Instagram
              </button>
            )}
          </div>

          {showReplyInput ? (
            <div className="flex items-center gap-2">
              <div className="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-primary/20 bg-primary/10 text-sm font-semibold text-primary">
                {user?.name?.charAt(0) || "U"}
              </div>

              <div className="flex flex-1 items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-3 py-2">
                <MessageCircle className="h-4 w-4 text-zinc-500" />
                <input
                  value={replyText}
                  onChange={(e) => setReplyText(e.target.value.slice(0, 120))}
                  placeholder="Reply to story..."
                  className="flex-1 bg-transparent text-sm text-white outline-none placeholder:text-zinc-500"
                  onKeyDown={(e) => {
                    if (e.key === "Enter") {
                      e.preventDefault()
                      submitReply()
                    }
                  }}
                />
                <button
                  onClick={submitReply}
                  disabled={!replyText.trim()}
                  className="flex h-8 w-8 items-center justify-center rounded-full bg-primary text-black disabled:opacity-40"
                >
                  <Send className="h-4 w-4" />
                </button>
              </div>
            </div>
          ) : (
            <div className="rounded-full border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-zinc-400">
              Community stories currently prioritize likes and quick reactions.
            </div>
          )}
        </div>
      </div>

      <style jsx global>{`
        .story-progress {
          width: 100%;
          transform-origin: left center;
          animation: storyProgressBar 4.5s linear forwards;
        }

        @keyframes storyProgressBar {
          0% {
            transform: scaleX(0);
          }
          100% {
            transform: scaleX(1);
          }
        }
      `}</style>
    </div>
  )
}

const circleBtnClass =
  "flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-[rgba(30,30,30,0.92)] text-white backdrop-blur-md"

const navBtnClass =
  "absolute top-1/2 z-[6] hidden -translate-y-1/2 items-center justify-center rounded-full border border-white/10 bg-[rgba(30,30,30,0.88)] p-3 text-white backdrop-blur-md md:flex"