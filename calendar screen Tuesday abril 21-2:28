                {parsedSelectedDate.toLocaleDateString("en-US", {
                  weekday: "short",
                  month: "short",
                  day: "numeric",
                  year: "numeric",
                })}
              </h3>
            </div>
          ) : (
            <>
              <div
                className="bg-card border border-primary/15 rounded-[24px] p-2 max-w-[330px] mx-auto"
                style={{
                  opacity: mounted ? 1 : 0,
                  transform: mounted ? "scale(1)" : "scale(0.985)",
                  transition:
                    "opacity 360ms ease 80ms, transform 420ms cubic-bezier(0.22, 1, 0.36, 1) 80ms",
                  boxShadow: "0 14px 36px rgba(0,0,0,0.18)",
                }}
              >
                <div className="flex items-center justify-between mb-2">
                  <button
                    onClick={prevMonth}
                    className="p-1.5 rounded-full hover:bg-secondary transition-colors"
                  >
                    <ChevronLeft className="h-5 w-5 text-foreground" />
                  </button>

                  <h3 className="text-[17px] font-serif font-semibold text-foreground">
                    {monthNames[month]} {year}
                  </h3>

                  <button
                    onClick={nextMonth}
                    className="p-1.5 rounded-full hover:bg-secondary transition-colors"
                  >
                    <ChevronRight className="h-5 w-5 text-foreground" />
                  </button>
                </div>

                <div className="grid grid-cols-7 gap-1 mb-1">
                  {dayNames.map((day, i) => (
                    <div
                      key={i}
                      className="text-center text-[11px] font-medium text-muted-foreground py-1"
                    >
                      {day}
                    </div>
                  ))}
                </div>

                <div className="grid grid-cols-7 gap-[3px]">
                  {calendarDays.map((day, i) =>
                    day === null ? (
                      <div key={i} />
                    ) : (
                      <button
                        key={i}
                        onClick={() => {
                          const newDate = new Date(year, month, day)
                          setSelectedDate(newDate.toISOString())
                        }}
                        className={`relative h-[40px] rounded-[10px] border flex items-center justify-center text-[13px] font-medium transition-all ${
                          isSelectedDay(day)
                            ? "bg-primary text-primary-foreground border-primary"
                            : "bg-card text-foreground border-border hover:bg-secondary"
                        }`}
                      >
                        <span>{day}</span>

                        {hasEventsOnDay(day) && (
                          <span
                            className={`absolute bottom-1.5 h-1.5 w-1.5 rounded-full ${
                              isSelectedDay(day)
                                ? "bg-primary-foreground"
                                : "bg-primary"
                            }`}
                          />
                        )}
                      </button>
                    )
                  )}
                </div>
              </div>

              <div className="flex items-center gap-2 border-b border-border py-3">
                <CalendarIcon className="h-5 w-5 text-primary" />
                <h3 className="text-[18px] font-semibold text-foreground">
                  {parsedSelectedDate.toLocaleDateString("en-US", {
                    weekday: "short",
                    month: "short",
                    day: "numeric",
                    year: "numeric",
                  })}
                </h3>
              </div>
            </>
          )}
        </div>

        <div className="flex-1 overflow-y-auto pt-3 space-y-3">
          {filteredEvents.length === 0 ? (
            <div className="py-10 text-center">
              <p className="text-muted-foreground">No events for this date</p>
              <p className="text-sm text-muted-foreground/70 mt-1">
                Try another day, search, or filters
              </p>
            </div>
          ) : (
            filteredEvents.map((event, index) => (
              <CompactEventCard
                key={event.id}
                event={event}
                index={index}
                mounted={mounted}
                isOpening={openingEventId === event.id}
                onOpen={() => handleEventSelect(event)}
              />
            ))
          )}
        </div>
      </div>

      <BottomNav />
    </div>
  )
}