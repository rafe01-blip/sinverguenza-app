function normalizeText(value?: string) {
  return (value || "").trim().toLowerCase()
}

function toggleValue(list: string[], value: string) {
  return list.includes(value)
    ? list.filter((item) => item !== value)
    : [...list, value]
}

function inferCategory(product: ProductType): ShopCategory {
  const raw = (product.category || "").toLowerCase()
  const name = (product.name || "").toLowerCase()

  if (raw.includes("womens") || raw.includes("women") || raw === "female") return "womens"
  if (raw.includes("mens") || raw.includes("men") || raw === "male") return "mens"
  if (raw.includes("auto") || name.includes("car") || name.includes("airpods") || name.includes("tire")) {
    return raw.includes("accessor") ? "accessories" : "auto"
  }
  if (raw.includes("accessor")) return "accessories"
  if (
    raw.includes("top") ||
    name.includes("hoodie") ||
    name.includes("tee") ||
    name.includes("tank")
  ) {
    return "tops"
  }
  return "accessories"
}

function enrichProduct(product: ProductType, index: number): EnhancedProduct {
  const shortDescription =
    product.shortDescription ||
    product.description?.slice(0, 74) ||
    "Premium Sin Vergüenza merch with signature black-and-gold identity."

  const category = inferCategory(product)

  const availability: EnhancedProduct["availability"] =
    typeof product.stock === "number"
      ? product.stock <= 0
        ? "out-of-stock"
        : product.stock <= 8
        ? "low-stock"
        : "in-stock"
      : "in-stock"

  return {
    ...product,
    category,
    shortDescription,
    images:
      product.images && product.images.length > 0
        ? product.images
        : [product.image || "/placeholder.svg"],
    featured: product.badge === "Best Seller" || product.badge === "New" || index < 2,
    availability,
    isBestSeller: product.badge === "Best Seller",
    isNew: product.badge === "New",
    isLimited: product.badge === "Limited",
    compareAtPrice:
      product.price >= 50 ? Number((product.price * 1.18).toFixed(0)) : undefined,
    material: "Premium signature finish",
    fit: "True to size",
    care: "Refer to care instructions",
    shippingNote: "Ships in 2–4 business days",
    gender: category === "mens" ? "male" : category === "womens" ? "female" : "unisex",
    sortOrder: index + 1,
    lifestyleImages: product.lifestyleImages ?? [],
  }
}

function getBadgeLabel(product: EnhancedProduct) {
  if (product.badge) return product.badge
  if (product.isBestSeller) return "Best Seller"
  if (product.isNew) return "New"
  if (product.isLimited) return "Limited"
  return ""
}

function getAvailabilityLabel(product: EnhancedProduct) {
  if (product.availability === "out-of-stock") return "Out of Stock"
  if (product.availability === "low-stock") return "Low Stock"
  return "In Stock"
}

