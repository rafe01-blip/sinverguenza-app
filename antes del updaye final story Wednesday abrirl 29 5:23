"use client"

import { useEffect, useMemo, useRef, useState } from "react"
import {
  ChevronLeft,
  ChevronRight,
  Heart,
  Instagram,
  Send,
  X,
} from "lucide-react"
import { useApp, StoryReaction } from "@/lib/app-context"

const STORY_REACTIONS: StoryReaction[] = ["❤️", "🔥", "👏", "🕺🏾", "💃", "😎", "🤣"]
const STORY_DURATION_MS = 4500

function timeAgoFromDate(dateString: string) {
  const now = Date.now()
  const then = new Date(dateString).getTime()
  const diff = Math.max(1, now - then)

  const minutes = Math.floor(diff / (1000 * 60))
  const hours = Math.floor(diff / (1000 * 60 * 60))
  const days = Math.floor(diff / (1000 * 60 * 60 * 24))

  if (minutes < 60) return `${minutes}m`
  if (hours < 24) return `${hours}h`
  return `${days}d`
}

export function StoryViewerScreen() {
  const {
    creators,
    user,
    selectedStoryId,
    setSelectedStoryId,
    setCurrentScreen,
    storySource,
    getStoriesForSource,
    markStorySeen,
    toggleStoryLike,
    addStoryReply,
    setStoryReaction,
  } = useApp()

  const stories = useMemo(() => {
    if (!storySource) return []
    return getStoriesForSource(storySource)
  }, [getStoriesForSource, storySource])

  const initialIndex = useMemo(() => {
    if (!selectedStoryId) return 0
    const index = stories.findIndex((s) => s.id === selectedStoryId)
    return index >= 0 ? index : 0
  }, [stories, selectedStoryId])

  const [activeIndex, setActiveIndex] = useState(initialIndex)
  const [activeSlideIndex, setActiveSlideIndex] = useState(0)
  const [replyText, setReplyText] = useState("")
  const [isPaused, setIsPaused] = useState(false)
  const [progressMs, setProgressMs] = useState(0)

  const progressStartRef = useRef<number | null>(null)
  const holdTimeoutRef = useRef<number | null>(null)
  const pressTriggeredRef = useRef(false)

  useEffect(() => {
    setActiveIndex(initialIndex)
    setActiveSlideIndex(0)
    setProgressMs(0)
    setIsPaused(false)
  }, [initialIndex])

  const story = stories[activeIndex]

  const creator = useMemo(() => {
    if (!story) return null
    return creators.find((c) => c.id === story.authorId) || null
  }, [story, creators])

  const slides = story?.slides ?? []
  const slide = slides[activeSlideIndex] || slides[0]

  useEffect(() => {
    if (!story) return
    markStorySeen(story.id)
  }, [story, markStorySeen])

  const handleClose = () => {
    setSelectedStoryId(null)
    setCurrentScreen(storySource === "home" ? "home" : "community")
  }

  const goToPrevious = () => {
    if (!story) return

    if (activeSlideIndex > 0) {
      setActiveSlideIndex((prev) => prev - 1)
      setProgressMs(0)
      return
    }

    if (activeIndex > 0) {
      const prevStory = stories[activeIndex - 1]
      setActiveIndex((prev) => prev - 1)
      setActiveSlideIndex(Math.max(0, (prevStory?.slides?.length ?? 1) - 1))
      setProgressMs(0)
      return
    }
  }

  const goToNext = () => {
    if (!story) return

    if (activeSlideIndex < slides.length - 1) {
      setActiveSlideIndex((prev) => prev + 1)
      setProgressMs(0)
      return
    }

    if (activeIndex < stories.length - 1) {
      setActiveIndex((prev) => prev + 1)
      setActiveSlideIndex(0)
      setProgressMs(0)
      return
    }

    handleClose()
  }

  useEffect(() => {
    if (!story || !slide || isPaused) return

    let frameId = 0

    const tick = (timestamp: number) => {
      if (progressStartRef.current === null) {
        progressStartRef.current = timestamp - progressMs
      }

      const elapsed = timestamp - progressStartRef.current
      setProgressMs(elapsed)

      if (elapsed >= STORY_DURATION_MS) {
        progressStartRef.current = null
        setProgressMs(0)
        goToNext()
        return
      }

      frameId = window.requestAnimationFrame(tick)
    }

    frameId = window.requestAnimationFrame(tick)

    return () => {
      window.cancelAnimationFrame(frameId)
      progressStartRef.current = null
    }
  }, [story?.id, activeSlideIndex, isPaused])

  const openInstagram = () => {
    const url = story?.instagramUrl || creator?.instagramUrl || creator?.socials?.instagram
    if (!url || typeof window === "undefined") return
    window.open(url, "_blank", "noopener,noreferrer")
  }

  const submitReply = () => {
    if (!replyText.trim()) return
    addStoryReply(story.id, replyText)
    setReplyText("")
  }

  const image =
    slide?.image ||
    story?.image ||
    creator?.coverImage ||
    creator?.avatar ||
    "/placeholder.svg"

  const reactionCount = Object.values(story?.quickReactions ?? {}).reduce(
    (sum, value) => sum + (value ?? 0),
    0
  )

  const repliesCount = story?.replies?.length ?? 0
  const showInstagram = Boolean(
    story?.instagramUrl || creator?.instagramUrl || creator?.socials?.instagram
  )
  const hasMultipleSlides = slides.length > 1

  const handlePressStart = () => {
    pressTriggeredRef.current = false
    if (holdTimeoutRef.current) {
      window.clearTimeout(holdTimeoutRef.current)
    }

    holdTimeoutRef.current = window.setTimeout(() => {
      pressTriggeredRef.current = true
      setIsPaused(true)
    }, 120)
  }

  const handlePressEnd = () => {
    if (holdTimeoutRef.current) {
      window.clearTimeout(holdTimeoutRef.current)
      holdTimeoutRef.current = null
    }

    if (pressTriggeredRef.current) {
      setIsPaused(false)
    }
  }

  if (!story || !creator || !slide) return null

  return (
    <div className="fixed inset-0 z-[100] bg-black">
      <img
        src={image}
        alt={slide.content || story.content || creator.name}
        className="absolute inset-0 h-full w-full object-cover"
      />

      <div className="absolute inset-0 bg-gradient-to-b from-black/45 via-transparent to-black/85" />

      <div className="absolute left-3 right-3 top-3 z-20 flex gap-1">
        {slides.map((item, index) => {
          const isPast = index < activeSlideIndex
          const isActive = index === activeSlideIndex
          const scale = isActive ? Math.min(progressMs / STORY_DURATION_MS, 1) : 0

          return (
            <div
              key={item.id}
              className="h-[2.5px] flex-1 overflow-hidden rounded-full bg-white/20"
            >
              {isPast && <div className="h-full w-full bg-white" />}
              {isActive && (
                <div
                  className="h-full origin-left bg-white"
                  style={{ transform: `scaleX(${scale})` }}
                />
              )}
            </div>
          )
        })}
      </div>

      <div className="absolute left-4 right-4 top-6 z-20 flex items-center justify-between">
        <div className="flex items-center gap-3">
          <button
            onClick={handleClose}
            className="flex h-10 w-10 items-center justify-center rounded-full bg-black/40 backdrop-blur-md"
          >
            <X className="h-5 w-5 text-white" />
          </button>

          <div className="h-10 w-10 overflow-hidden rounded-full border border-primary">
            <img
              src={creator.avatar || "/placeholder.svg"}
              alt={creator.name}
              className="h-full w-full object-cover"
            />
          </div>

          <div className="min-w-0">
            <button
              type="button"
              onClick={showInstagram ? openInstagram : undefined}
              className={`max-w-[180px] truncate text-left text-sm font-semibold text-white ${
                showInstagram ? "hover:text-primary" : ""
              }`}
            >
              {creator.displayName || creator.name}
            </button>
            <p className="text-xs text-zinc-400">{timeAgoFromDate(story.createdAt)}</p>
          </div>
        </div>

        {showInstagram && (
          <button onClick={openInstagram} className="text-primary">
            <Instagram className="h-5 w-5" />
          </button>
        )}
      </div>

      <div className="absolute inset-0 z-10 flex">
        <button
          className="flex-1"
          onPointerDown={handlePressStart}
          onPointerUp={handlePressEnd}
          onPointerLeave={handlePressEnd}
          onTouchStart={handlePressStart}
          onTouchEnd={handlePressEnd}
          onClick={goToPrevious}
          aria-label="Previous story"
        />
        <button
          className="flex-1"
          onPointerDown={handlePressStart}
          onPointerUp={handlePressEnd}
          onPointerLeave={handlePressEnd}
          onTouchStart={handlePressStart}
          onTouchEnd={handlePressEnd}
          onClick={goToNext}
          aria-label="Next story"
        />
      </div>

      {hasMultipleSlides && (
        <>
          <button
            onClick={goToPrevious}
            className="absolute left-4 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/10 bg-black/35 text-white backdrop-blur-md"
            aria-label="Previous slide"
          >
            <ChevronLeft className="h-5 w-5" />
          </button>

          <button
            onClick={goToNext}
            className="absolute right-4 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/10 bg-black/35 text-white backdrop-blur-md"
            aria-label="Next slide"
          >
            <ChevronRight className="h-5 w-5" />
          </button>
        </>
      )}

      <div className="absolute bottom-5 left-4 right-4 z-20">
        <div className="rounded-[22px] border border-white/10 bg-black/65 p-3 backdrop-blur-xl">
          <div className="mb-2 flex items-start justify-between gap-3">
            <div className="min-w-0">
              <h2 className="truncate text-[15px] font-semibold text-white">
                {slide.content || story.content}
              </h2>
              {repliesCount > 0 && (
                <p className="mt-1 text-[11px] text-zinc-400">
                  {repliesCount} {repliesCount === 1 ? "reply" : "replies"}
                </p>
              )}
            </div>

            <button
              onClick={() => toggleStoryLike(story.id)}
              className={`inline-flex h-9 items-center gap-1.5 rounded-full px-3 text-xs ${
                story.isLiked ? "bg-red-500/15 text-red-400" : "bg-white/10 text-white"
              }`}
            >
              <Heart className="h-4 w-4" />
              <span>{story.likesCount ?? 0}</span>
            </button>
          </div>

          <div className="mb-3 flex flex-wrap gap-2">
            {STORY_REACTIONS.map((reaction) => (
              <button
                key={reaction}
                onClick={() => setStoryReaction(story.id, reaction)}
                className={`flex h-8 min-w-[34px] items-center justify-center rounded-full px-2 text-sm ${
                  story.myReaction === reaction
                    ? "bg-primary/20"
                    : "bg-white/10 text-white"
                }`}
              >
                {reaction}
              </button>
            ))}
          </div>

          {storySource === "home" && (
            <div className="flex gap-2">
              <input
                value={replyText}
                onChange={(e) => setReplyText(e.target.value)}
                placeholder="Reply..."
                className="h-10 flex-1 rounded-full bg-white/10 px-3 text-sm text-white outline-none placeholder:text-zinc-400"
              />
              <button
                onClick={submitReply}
                className="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-black"
                aria-label="Send reply"
              >
                <Send className="h-4 w-4" />
              </button>
            </div>
          )}

          {reactionCount > 0 && (
            <div className="mt-2 text-[11px] text-zinc-500">
              {reactionCount} reactions
            </div>
          )}
        </div>
      </div>
    </div>
  )
}