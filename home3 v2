function formatTime12h(time: string) {
  const [h, m] = time.split(":").map(Number)
  const period = h >= 12 ? "PM" : "AM"
  const hour = h % 12 || 12
  return `${hour}:${m.toString().padStart(2, "0")} ${period}`
}

function getDateString(date: Date) {
  return date.toISOString().split("T")[0]
}

function formatDateChip(date: Date) {
  return date.toLocaleDateString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
  })
}

function shortText(text?: string) {
  const cleaned = (text || "").replace(/\s+/g, " ").trim()
  if (cleaned.length <= 72) return cleaned
  return cleaned.slice(0, 72) + "..."
}

function getCategoryLabel(event: EventType) {
  if (event.category === "class") return "Class"
  if (event.category === "announcement") return "Announcement"
  return "Event"
}

function isFreeEvent(event: EventType) {
  return event.pricing === "free" || event.price === 0
}

function isPublicEvent(event: EventType) {
  return event.visibility === "public" || event.isPublic === true
}

function isWorkshopEvent(event: EventType) {
  return event.activityTypes?.includes("workshop") || false
}

function isDanceEvent(event: EventType) {
  return event.activityTypes?.includes("dance") || false
}

function getPrimaryTag(event: EventType) {
  if (isFreeEvent(event)) return "Free"
  return `$${event.price ?? 0}`
}

function getTagTone(label: string) {
  if (label === "Free") return "emerald"
  if (label === "Public") return "cyan"
  if (label === "Private") return "orange"
  if (label === "Workshop") return "gold"
  if (label === "Dance") return "pink"
  return "default"
}

function Pill({
  label,
  tone = "default",
}: {
  label: string
  tone?: "default" | "emerald" | "cyan" | "orange" | "gold" | "pink"
}) {
  const toneClass =
    tone === "emerald"
      ? "border-emerald-500/30 bg-emerald-500/12 text-emerald-400"
      : tone === "cyan"
      ? "border-cyan-500/30 bg-cyan-500/12 text-cyan-400"
      : tone === "orange"
      ? "border-orange-500/30 bg-orange-500/12 text-orange-400"
      : tone === "gold"
      ? "border-primary/30 bg-primary/12 text-primary"
      : tone === "pink"
      ? "border-pink-500/30 bg-pink-500/12 text-pink-400"
      : "border-white/10 bg-white/[0.04] text-zinc-300"

  return (
    <span
      className={`inline-flex items-center rounded-full border px-2.5 py-1 text-[10px] font-medium ${toneClass}`}
    >
      {label}
    </span>
  )
}

function DateSelector({
  date,
  setDate,
}: {
  date: Date
  setDate: (date: Date) => void
}) {
  const prev = () => {
    const d = new Date(date)
    d.setDate(d.getDate() - 1)
    setDate(d)
  }

  const next = () => {
    const d = new Date(date)
    d.setDate(d.getDate() + 1)
    setDate(d)
  }

  return (
    <div className="flex items-center gap-1.5 rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 shadow-[0_10px_24px_rgba(0,0,0,0.18)]">
      <button
        onClick={prev}
        className="rounded-full p-1 text-zinc-400 hover:bg-white/[0.06] hover:text-white transition-colors"
      >
        <ChevronLeft className="h-4 w-4" />
      </button>

      <span className="min-w-[98px] text-center text-sm font-medium text-white">
        {formatDateChip(date)}
      </span>

      <button
        onClick={next}
        className="rounded-full p-1 text-zinc-400 hover:bg-white/[0.06] hover:text-white transition-colors"
      >
        <ChevronRight className="h-4 w-4" />
      </button>
    </div>
  )
}

