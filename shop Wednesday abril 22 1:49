function Badge({ label }: { label: string }) {
  if (!label) return null
  return <div style={badgeStyle}>{label}</div>
}

function ProductCard({
  product,
  isFavorite,
  onToggleFavorite,
  onOpen,
  onQuickAdd,
}: {
  product: EnhancedProduct
  isFavorite: boolean
  onToggleFavorite: () => void
  onOpen: () => void
  onQuickAdd: () => void
}) {
  const badge = getBadgeLabel(product)
  const outOfStock = product.availability === "out-of-stock"

  return (
    <div style={productCard}>
      <div onClick={onOpen} style={imageHitArea}>
        <img
          src={product.images?.[0] || "/placeholder.svg"}
          alt={product.name}
          style={productImage}
        />
        <div style={imageOverlay} />

        {badge && <Badge label={badge} />}

        <button
          onClick={(e) => {
            e.stopPropagation()
            onToggleFavorite()
          }}
          style={favoriteBtn}
        >
          {isFavorite ? "★" : "☆"}
        </button>

        <div style={tapToViewWrap}>
          <span style={tapToViewText}>Tap to View</span>
        </div>
      </div>

      <div style={cardBody}>
        <div style={productName}>{product.name}</div>
        <div style={productDesc}>{product.shortDescription}</div>

        <div style={metaRow}>
          <div style={priceWrap}>
            <div style={priceText}>${product.price}</div>
            {product.compareAtPrice ? (
              <div style={compareAtText}>${product.compareAtPrice}</div>
            ) : null}
          </div>

          <div style={stockText}>{getAvailabilityLabel(product)}</div>
        </div>

        <div style={sizesLine}>
          {product.sizes?.length ? `${product.sizes.length} sizes` : "One size"}
        </div>

        <button
          onClick={onQuickAdd}
          disabled={outOfStock}
          style={{
            ...addCartBtn,
            opacity: outOfStock ? 0.45 : 1,
            cursor: outOfStock ? "not-allowed" : "pointer",
          }}
        >
          <ShoppingBag size={15} />
          <span>{outOfStock ? "Unavailable" : "Add to Cart"}</span>
        </button>
      </div>
    </div>
  )
}

export function ShopScreen() {
  const {
    products,
    setSelectedProduct,
    setCurrentScreen,
    addToCart,
    cartItems,
  } = useApp()

  const collectionRef = useRef<HTMLDivElement | null>(null)

  const [activeCategory, setActiveCategory] = useState<ShopCategory>("all")
  const [searchQuery, setSearchQuery] = useState("")
  const [sortBy, setSortBy] = useState<SortKey>("featured")
  const [filtersOpen, setFiltersOpen] = useState(false)
  const [selectedSizes, setSelectedSizes] = useState<string[]>([])
  const [selectedColors, setSelectedColors] = useState<string[]>([])
  const [priceFilter, setPriceFilter] = useState<"all" | "under-25" | "25-50" | "over-50">("all")
  const [availabilityFilter, setAvailabilityFilter] = useState<"all" | "in-stock" | "low-stock" | "out-of-stock">("all")
  const [favorites, setFavorites] = useState<Record<string, boolean>>({})

  const sourceProducts = useMemo<EnhancedProduct[]>(() => {
    if (products.length > 0) {
      return products.map((product, index) => enrichProduct(product, index))
    }
    return DEMO_PRODUCTS
  }, [products])

  const categoryProducts = useMemo(() => {
    if (activeCategory === "all") return sourceProducts
    return sourceProducts.filter((product) => product.category === activeCategory)
  }, [activeCategory, sourceProducts])

  const allSizes = useMemo(() => {
    return [...new Set(sourceProducts.flatMap((p) => p.sizes || []))].slice(0, 12)
  }, [sourceProducts])

  const allColors = useMemo(() => {
    return [...new Set(sourceProducts.flatMap((p) => p.colors || []))].slice(0, 10)
  }, [sourceProducts])

  const filteredProducts = useMemo(() => {
    let result = [...categoryProducts]

    if (searchQuery.trim()) {
      const q = normalizeText(searchQuery)
      result = result.filter((product) =>
        normalizeText(
          [product.name, product.shortDescription, product.description, product.category].join(" ")
        ).includes(q)
      )
    }

    if (selectedSizes.length > 0) {
      result = result.filter((product) => {
        const productSizes = (product.sizes || []).map((size) => normalizeText(size))
        return selectedSizes.some((size) => productSizes.includes(normalizeText(size)))
      })
    }

    if (selectedColors.length > 0) {
      result = result.filter((product) => {
        const productColors = (product.colors || []).map((color) => normalizeText(color))
        return selectedColors.some((color) => productColors.includes(normalizeText(color)))
      })
    }

    if (priceFilter !== "all") {
      result = result.filter((product) => {
        if (priceFilter === "under-25") return product.price < 25
        if (priceFilter === "25-50") return product.price >= 25 && product.price <= 50
        if (priceFilter === "over-50") return product.price > 50
        return true
      })
    }

    if (availabilityFilter !== "all") {
      result = result.filter(
        (product) => normalizeText(product.availability) === normalizeText(availabilityFilter)
      )
    }

    switch (sortBy) {
      case "price-low":
        result.sort((a, b) => a.price - b.price)
        break
      case "price-high":
        result.sort((a, b) => b.price - a.price)
        break
      case "newest":
        result.sort((a, b) => (a.sortOrder ?? 999) - (b.sortOrder ?? 999))
        break
      case "featured":
      default:
        result.sort((a, b) => {
          const aScore =
            (a.featured ? 3 : 0) +
            (a.isBestSeller ? 2 : 0) +
            (a.isNew ? 1 : 0) +
            (a.isLimited ? 1 : 0)

          const bScore =
            (b.featured ? 3 : 0) +
            (b.isBestSeller ? 2 : 0) +
            (b.isNew ? 1 : 0) +
            (b.isLimited ? 1 : 0)

          return bScore - aScore
        })
        break
    }

    return result
  }, [
    categoryProducts,
    searchQuery,
    selectedSizes,
    selectedColors,
    priceFilter,
    availabilityFilter,
    sortBy,
  ])

  const featuredProducts = useMemo(() => {
    return sourceProducts.filter((product) => product.featured).slice(0, 4)
  }, [sourceProducts])

  const cartCount = cartItems.reduce((sum, item) => sum + item.quantity, 0)

  const openProduct = (product: EnhancedProduct) => {
    setSelectedProduct(product)
    setCurrentScreen("product-detail")
  }

  const quickAddToCart = (product: EnhancedProduct) => {
    const size = product.sizes?.[0] || "One Size"
    const color = product.colors?.[0] || "Default"

    addToCart({
      product,
      size,
      color,
      quantity: 1,
    })
  }

  const toggleFavorite = (productId: string) => {
    setFavorites((prev) => ({
      ...prev,
      [productId]: !prev[productId],
    }))
  }

  const clearFilters = () => {
    setSelectedSizes([])
    setSelectedColors([])
    setPriceFilter("all")
    setAvailabilityFilter("all")
    setSearchQuery("")
    setSortBy("featured")
  }

  const activeFilterCount =
    selectedSizes.length +
    selectedColors.length +
    (priceFilter !== "all" ? 1 : 0) +
    (availabilityFilter !== "all" ? 1 : 0) +
    (searchQuery.trim() ? 1 : 0)

  return (
    <div
      style={{
        minHeight: "100vh",
        background: DARK,
        color: "#fff",
        paddingBottom: 110,
      }}
    >
      <TopHeader title="Shop" />

      <div style={{ padding: "16px" }}>
        <ShopHero
          onShopNow={() =>
            collectionRef.current?.scrollIntoView({ behavior: "smooth", block: "start" })
          }
        />

        <div style={toolbarWrap}>
          <div style={searchWrap}>
            <Search size={18} color="#a7a7a7" />
            <input
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              placeholder="Search merch"
              style={searchInput}
            />
            {searchQuery ? (
              <button onClick={() => setSearchQuery("")} style={clearSearchBtn}>
                <X size={15} />
              </button>
            ) : null}
          </div>

          <button onClick={() => setCurrentScreen("cart")} style={cartPillBtn}>
            <ShoppingBag size={16} />
            <span>Cart</span>
            {cartCount > 0 ? <span style={cartCountBubble}>{cartCount}</span> : null}
          </button>
        </div>

        <div style={controlsRow}>
          <button
            type="button"
            onClick={() => setFiltersOpen((prev) => !prev)}
            style={filtersOpen || activeFilterCount > 0 ? chipActiveWide : chipWide}
          >
            <SlidersHorizontal size={16} />
            <span>
              Filter{activeFilterCount > 0 ? ` (${activeFilterCount})` : ""}
            </span>
          </button>

          <select
            value={sortBy}
            onChange={(e) => setSortBy(e.target.value as SortKey)}
            style={sortSelect}
          >
            <option value="featured">Featured</option>
            <option value="newest">Newest</option>
            <option value="price-low">Price low to high</option>
            <option value="price-high">Price high to low</option>
          </select>
        </div>

        {filtersOpen ? (
          <div style={filtersPanel}>
            <div style={filterGroup}>
              <div style={filterTitle}>Size</div>
              <div style={rowWrap}>
                {allSizes.map((size) => {
                  const active = selectedSizes.includes(size)
                  return (
                    <button
                      key={size}
                      onClick={() => setSelectedSizes((prev) => toggleValue(prev, size))}
                      style={active ? chipActiveSmall : chipSmall}
                    >
                      {size}
                    </button>
                  )
                })}
              </div>
            </div>

            <div style={filterGroup}>
              <div style={filterTitle}>Color</div>
              <div style={rowWrap}>
                {allColors.map((color) => {
                  const active = selectedColors.includes(color)
                  return (
                    <button
                      key={color}
                      onClick={() => setSelectedColors((prev) => toggleValue(prev, color))}
                      style={active ? chipActiveSmall : chipSmall}
                    >
                      {color}
                    </button>
                  )
                })}
              </div>
            </div>

            <div style={filterGroup}>
              <div style={filterTitle}>Price</div>
              <div style={rowWrap}>
                {[
                  { key: "all", label: "All" },
                  { key: "under-25", label: "Under $25" },
                  { key: "25-50", label: "$25–$50" },
                  { key: "over-50", label: "Over $50" },
                ].map((item) => (
                  <button
                    key={item.key}
                    onClick={() => setPriceFilter(item.key as typeof priceFilter)}
                    style={priceFilter === item.key ? chipActiveSmall : chipSmall}
                  >
                    {item.label}
                  </button>
                ))}
              </div>
            </div>

            <div style={filterGroup}>
              <div style={filterTitle}>Availability</div>
              <div style={rowWrap}>
                {[
                  { key: "all", label: "All" },
                  { key: "in-stock", label: "In Stock" },
                  { key: "low-stock", label: "Low Stock" },
                  { key: "out-of-stock", label: "Out of Stock" },
                ].map((item) => (
                  <button
                    key={item.key}
                    onClick={() =>
                      setAvailabilityFilter(item.key as typeof availabilityFilter)
                    }
                    style={availabilityFilter === item.key ? chipActiveSmall : chipSmall}
                  >
                    {item.label}
                  </button>
                ))}
              </div>
            </div>

            <button onClick={clearFilters} style={clearFiltersBtn}>
              Clear Filters
            </button>
          </div>
        ) : null}

        <div
          style={{
            color: GOLD,
            fontSize: 14,
            fontWeight: 900,
            letterSpacing: 3,
            textTransform: "uppercase",
            marginBottom: 14,
          }}
        >
          Merch Shop
        </div>

        <div style={categoriesScroll}>
          {CATEGORY_LABELS.map((category) => (
            <button
              key={category.key}
              onClick={() => setActiveCategory(category.key)}
              style={activeCategory === category.key ? categoryChipActive : categoryChip}
            >
              {category.label}
            </button>
          ))}
        </div>

        {featuredProducts.length > 0 ? (
          <div style={{ marginBottom: 24 }}>
            <div style={sectionHeading}>
              <span>Featured</span>
              <div style={sectionHint}>
                Curated picks <Sparkles size={14} />
              </div>
            </div>

            <div style={featuredScroll}>
              {featuredProducts.map((product) => (
                <button
                  key={product.id}
                  onClick={() => openProduct(product)}
                  style={featuredCard}
                >
                  <div style={featuredImageWrap}>
                    <img
                      src={product.images?.[0] || "/placeholder.svg"}
                      alt={product.name}
                      style={featuredImage}
                    />
                    <div style={featuredOverlay} />
                    {getBadgeLabel(product) ? <Badge label={getBadgeLabel(product)} /> : null}
                  </div>

                  <div style={featuredBody}>
                    <div style={featuredName}>{product.name}</div>
                    <div style={featuredDesc}>{product.shortDescription}</div>
                    <div style={featuredBottom}>
                      <span style={featuredPrice}>${product.price}</span>
                      <span style={featuredArrow}>
                        View <ChevronRight size={14} />
                      </span>
                    </div>
                  </div>
                </button>
              ))}
            </div>
          </div>
        ) : null}

        <div ref={collectionRef}>
          <div style={sectionHeading}>
            <span>Collection</span>
            <div style={sectionCount}>{filteredProducts.length} items</div>
          </div>

          {filteredProducts.length === 0 ? (
            <div style={emptyWrap}>
              <div style={emptyIcon}>✦</div>
              <div style={emptyTitle}>No products found</div>
              <div style={emptyText}>
                Try another category, search term, or filter combination.
              </div>
              <button onClick={clearFilters} style={goShopBtn}>
                Reset Filters
              </button>
            </div>
          ) : (
            <div style={productGrid}>
              {filteredProducts.map((product) => (
                <ProductCard
                  key={product.id}
                  product={product}
                  isFavorite={!!favorites[product.id]}
                  onToggleFavorite={() => toggleFavorite(product.id)}
                  onOpen={() => openProduct(product)}
                  onQuickAdd={() => quickAddToCart(product)}
                />
              ))}
            </div>
          )}
        </div>
      </div>

      <BottomNav />
    </div>
  )
}

