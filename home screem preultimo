          <div className="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl border border-primary/25 bg-black/30 text-primary">
            <Bell className="h-4.5 w-4.5" />
          </div>

          <div className="min-w-0">
            <p className="truncate text-[14px] font-semibold text-white">
              {pinnedEvents.length === 1
                ? firstPinned.title
                : `${pinnedEvents.length} events pinned`}
            </p>
            <p className="truncate text-[12px] text-zinc-400">{metaLabel}</p>
          </div>
        </div>

        <Sparkles className="h-4 w-4 shrink-0 text-primary transition-transform duration-200 group-active:translate-x-[2px]" />
