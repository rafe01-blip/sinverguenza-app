function normalizeComments(comments?: EventComment[]) {
  return (comments ?? []).map((comment) => ({
    ...comment,
    replies: comment.replies ?? [],
  }))
}

function normalizeProduct(product: ProductType, index: number): ProductType {
  const stock = typeof product.stock === "number" ? product.stock : 12
  const availability: ProductType["availability"] =
    stock <= 0 ? "out-of-stock" : stock <= 8 ? "low-stock" : "in-stock"

  return {
    ...product,
    image: product.image || product.images?.[0] || "/placeholder.svg",
    images:
      product.images && product.images.length > 0
        ? product.images
        : [product.image || "/placeholder.svg"],
    lifestyleImages: product.lifestyleImages ?? [],
    shortDescription:
      product.shortDescription ||
      product.description?.slice(0, 80) ||
      "Premium Sin Vergüenza merch with signature black-and-gold identity.",
    stock,
    availability,
    compareAtPrice:
      product.compareAtPrice ??
      (product.price >= 50 ? Number((product.price * 1.18).toFixed(0)) : undefined),
    featured:
      product.featured ??
      (product.badge === "Best Seller" || product.badge === "New" || index < 2),
    isBestSeller: product.isBestSeller ?? product.badge === "Best Seller",
    isNew: product.isNew ?? product.badge === "New",
    isLimited: product.isLimited ?? product.badge === "Limited",
    material: product.material ?? "Premium signature finish",
    fit: product.fit ?? "True to size",
    care: product.care ?? "Refer to care instructions",
    shippingNote: product.shippingNote ?? "Ships in 2–4 business days",
    gender: product.gender ?? "unisex",
    sortOrder: product.sortOrder ?? index + 1,
  }
}

function normalizeCreator(creator: Creator): Creator {
  const roleLower = String(creator.role || creator.badgeLabel || "member").toLowerCase()

  const badgeLabel: CreatorBadgeLabel =
    creator.badgeLabel ||
    (roleLower.includes("official")
      ? "Official"
      : roleLower.includes("instructor")
      ? "Instructor"
      : roleLower.includes("host")
      ? "Host"
      : "Member")

  const role: CreatorRole =
    roleLower.includes("official")
      ? "official"
      : roleLower.includes("instructor")
      ? "instructor"
      : roleLower.includes("host")
      ? "host"
      : "member"

  return {
    ...creator,
    displayName: creator.displayName || creator.name,
    badgeLabel,
    role,
    avatar: creator.avatar || "/placeholder.svg",
    coverImage: creator.coverImage || "/placeholder.svg",
    followers: creator.followers ?? creator.followersCount ?? 0,
    following: creator.following ?? creator.followingCount ?? 0,
    posts: creator.posts ?? creator.postsCount ?? 0,
    events: creator.events ?? creator.eventsCount ?? 0,
    followersCount: creator.followersCount ?? creator.followers ?? 0,
    followingCount: creator.followingCount ?? creator.following ?? 0,
    postsCount: creator.postsCount ?? creator.posts ?? 0,
    eventsCount: creator.eventsCount ?? creator.events ?? 0,
    totalLikes: creator.totalLikes ?? 0,
    isFollowing: creator.isFollowing ?? false,
    isVerified: creator.isVerified ?? badgeLabel === "Official",
    instagramUrl:
      creator.instagramUrl ||
      (creator.instagram
        ? `https://instagram.com/${creator.instagram.replace("@", "")}`
        : creator.socials?.instagram),
  }
}

