import { TopHeader } from "@/components/navigation/top-header"

const GOLD = "#C9A84C"
const DARK = "#0A0A0A"
const CARD = "#121212"

type EnhancedProduct = ProductType & {
  compareAtPrice?: number
  gender?: "male" | "female" | "unisex"
  material?: string
  fit?: string
  care?: string
  shippingNote?: string
  availability?: "in-stock" | "low-stock" | "out-of-stock"
  featured?: boolean
  isNew?: boolean
  isBestSeller?: boolean
  isLimited?: boolean
  sortOrder?: number
  lifestyleImages?: string[]
}

function getBadgeLabel(product: EnhancedProduct) {
  if (product.badge) return product.badge
  if (product.isBestSeller) return "Best Seller"
  if (product.isNew) return "New"
  if (product.isLimited) return "Limited"
  return ""
}

function getAvailabilityLabel(product: EnhancedProduct) {
  if (product.availability === "out-of-stock") return "Out of Stock"
  if (product.availability === "low-stock") return "Low Stock"
  return "In Stock"
}

function normalizeProduct(product: ProductType | null): EnhancedProduct | null {
  if (!product) return null

  const stock = typeof product.stock === "number" ? product.stock : 12
  const availability: EnhancedProduct["availability"] =
    stock <= 0 ? "out-of-stock" : stock <= 8 ? "low-stock" : "in-stock"

  const images =
    product.images && product.images.length > 0
      ? product.images
      : [product.image || "/placeholder.svg"]

  return {
    ...product,
    images,
    compareAtPrice:
      product.price >= 50 ? Number((product.price * 1.18).toFixed(0)) : undefined,
    material: "Premium signature finish",
    fit: "True to size",
    care: "Refer to care instructions",
    shippingNote: "Ships in 2–4 business days",
    availability,
    gender: "unisex",
    lifestyleImages: [],
  }
}

export function ProductDetailScreen() {
  const {
    selectedProduct,
    products,
    goBack,
    addToCart,
    setCurrentScreen,
    setSelectedProduct,
  } = useApp()

  const product = useMemo(
    () => normalizeProduct(selectedProduct),
    [selectedProduct]
  )

  const [imageIndex, setImageIndex] = useState(0)
  const [favorite, setFavorite] = useState(false)
  const [selectedSize, setSelectedSize] = useState("")
  const [selectedColor, setSelectedColor] = useState("")
  const [quantity, setQuantity] = useState(1)
  const [addedFlash, setAddedFlash] = useState(false)

  const galleryImages = useMemo(() => {
    if (!product) return ["/placeholder.svg"]
    const base = product.images && product.images.length > 0 ? product.images : ["/placeholder.svg"]
    const lifestyle = product.lifestyleImages || []
    const merged = [...base, ...lifestyle]
    return merged.length > 0 ? merged.slice(0, 6) : ["/placeholder.svg"]
  }, [product])

  const relatedProducts = useMemo(() => {
    if (!product) return []
    return products
      .filter((item) => item.id !== product.id)
      .filter((item) => (item.category || "") === (product.category || ""))
      .slice(0, 4)
  }, [products, product])

  if (!product) return null

  const nextImage = () => {
    setImageIndex((prev) => (prev === galleryImages.length - 1 ? 0 : prev + 1))
  }

  const previousImage = () => {
    setImageIndex((prev) => (prev === 0 ? galleryImages.length - 1 : prev - 1))
  }

  const handleAddToCart = () => {
    const size = selectedSize || product.sizes?.[0] || "One Size"
    const color = selectedColor || product.colors?.[0] || "Default"

    addToCart({
      product,
      size,
      color,
      quantity,
    })

    setAddedFlash(true)
    setTimeout(() => {
      setAddedFlash(false)
      setCurrentScreen("cart")
    }, 700)
  }

  const badge = getBadgeLabel(product)
  const outOfStock = product.availability === "out-of-stock"

  return (
    <div
      style={{
        minHeight: "100vh",
        background: DARK,
        color: "#fff",
        paddingBottom: 120,
      }}
    >
      <TopHeader title="Product" />

      <div style={{ padding: "12px 16px 0" }}>
        <button onClick={goBack} style={backBtn}>
          ← Back
        </button>
      </div>

      <div style={heroWrap}>
        <img
          src={galleryImages[imageIndex]}
          alt={product.name}
          style={heroImage}
        />

        <div style={heroOverlay} />

        <button onClick={() => setFavorite(!favorite)} style={favoriteBtn}>
          <Bookmark
            size={20}
            fill={favorite ? GOLD : "transparent"}
            color={favorite ? GOLD : "#fff"}
          />
        </button>

        {badge ? <div style={badgeStyle}>{badge}</div> : null}

        {galleryImages.length > 1 && (
          <>
            <button onClick={previousImage} style={{ ...navBtn, left: 16 }}>
              <ChevronLeft size={24} />
            </button>

            <button onClick={nextImage} style={{ ...navBtn, right: 16 }}>
              <ChevronRight size={24} />
            </button>
          </>
        )}
      </div>

      <div style={{ padding: "0 16px" }}>
        <div style={dotsWrap}>
          {galleryImages.map((_, index) => (
            <button
              key={index}
              onClick={() => setImageIndex(index)}
              style={{
                ...dotBase,
                width: imageIndex === index ? 24 : 8,
                background:
                  imageIndex === index ? GOLD : "rgba(255,255,255,0.22)",
              }}
            />
          ))}
        </div>

        <div style={imageCountText}>
          {imageIndex + 1}/{galleryImages.length}
        </div>

        <div style={headerRow}>
          <div style={{ flex: 1 }}>
            <div style={productName}>{product.name}</div>
            <div style={stockRow}>
              <span style={stockBadge}>{getAvailabilityLabel(product)}</span>
            </div>
          </div>

          <div style={priceBlock}>
            <div style={priceText}>${product.price}</div>
            {product.compareAtPrice ? (
              <div style={compareText}>${product.compareAtPrice}</div>
            ) : null}
          </div>
        </div>

        <div style={descriptionLead}>
          {product.shortDescription || "Premium Sin Vergüenza merch with elevated black-and-gold identity."}
        </div>

        {product.sizes?.length ? (
          <div style={sectionCard}>
            <div style={sectionTitle}>Select Size</div>
            <div style={rowWrap}>
              {product.sizes.map((size) => (
                <button
                  key={size}
                  onClick={() => setSelectedSize(size)}
                  style={selectedSize === size ? chipActive : chip}
                >
                  {size}
                </button>
              ))}
            </div>
          </div>
        ) : null}

        {product.colors?.length ? (
          <div style={sectionCard}>
            <div style={sectionTitle}>Select Color</div>
            <div style={rowWrap}>
              {product.colors.map((color) => (
                <button
                  key={color}
                  onClick={() => setSelectedColor(color)}
                  style={selectedColor === color ? chipActive : chip}
                >
                  {color}
                </button>
              ))}
            </div>
          </div>
        ) : null}

        <div style={sectionCard}>
          <div style={sectionTitle}>Quantity</div>
          <div style={qtyRow}>
            <button
              onClick={() => setQuantity((prev) => (prev > 1 ? prev - 1 : 1))}
              style={qtyBtn}
            >
              <Minus size={18} />
            </button>

            <div style={qtyValue}>{quantity}</div>

            <button
              onClick={() => setQuantity((prev) => prev + 1)}
              style={qtyBtn}
            >
              <Plus size={18} />
            </button>
          </div>
        </div>

        <div style={infoGrid}>
          <div style={infoCard}>
            <div style={infoLabel}>Material</div>
            <div style={infoValue}>{product.material || "Premium signature finish"}</div>
          </div>

          <div style={infoCard}>
            <div style={infoLabel}>Fit</div>
            <div style={infoValue}>{product.fit || "True to size"}</div>
          </div>

          <div style={infoCard}>
            <div style={infoLabel}>Care</div>
            <div style={infoValue}>{product.care || "Refer to care instructions"}</div>
          </div>

          <div style={infoCard}>
            <div style={infoLabel}>Shipping</div>
            <div style={infoValue}>{product.shippingNote || "Ships in 2–4 business days"}</div>
          </div>
        </div>

        <div style={descriptionCard}>
          <div style={detailHeading}>Product Details</div>
          <div style={detailText}>
            {product.description ||
              "Premium Sin Vergüenza merch built with a clean, elevated visual identity that feels more like a lifestyle brand than basic merch."}
          </div>
        </div>

        {relatedProducts.length > 0 ? (
          <div style={{ marginBottom: 18 }}>
            <div style={relatedHeading}>You may also like</div>

            <div style={relatedScroll}>
              {relatedProducts.map((item) => (
                <button
                  key={item.id}
                  onClick={() => {
                    setSelectedProduct(item)
                    setImageIndex(0)
                    setSelectedSize("")
                    setSelectedColor("")
                    setQuantity(1)
                    setFavorite(false)
                  }}
                  style={relatedCard}
                >
                  <img
                    src={item.images?.[0] || item.image || "/placeholder.svg"}
                    alt={item.name}
                    style={relatedImage}
                  />
                  <div style={relatedBody}>
                    <div style={relatedName}>{item.name}</div>
                    <div style={relatedPrice}>${item.price}</div>
                  </div>
                </button>
              ))}
            </div>
          </div>
        ) : null}
      </div>

      <div style={stickyFooter}>
        <div style={footerPriceWrap}>
          <div style={footerPriceLabel}>Total</div>
          <div style={footerPriceValue}>${product.price * quantity}</div>
        </div>

        <button
          onClick={handleAddToCart}
          disabled={outOfStock}
          style={{
            ...addToCartBtn,
            opacity: outOfStock ? 0.45 : 1,
            cursor: outOfStock ? "not-allowed" : "pointer",
          }}
        >
          <ShoppingBag size={18} />
          <span>
            {outOfStock
              ? "Unavailable"
              : addedFlash
              ? "Added to Cart"
              : "Add to Cart"}
          </span>
        </button>
      </div>
    </div>
  )
}

