type WeatherState = {
  temp: number
  label: string
  icon: "sun" | "cloud" | "rain"
  cityLabel: string
}

function formatTime12h(time: string) {
  const [h, m] = time.split(":").map(Number)
  const period = h >= 12 ? "PM" : "AM"
  const hour = h % 12 || 12
  return `${hour}:${m.toString().padStart(2, "0")} ${period}`
}

function getDateString(date: Date) {
  return date.toISOString().split("T")[0]
}

function formatDateChip(date: Date) {
  return date.toLocaleDateString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
  })
}

function shortText(text?: string, max = 60) {
  const cleaned = (text || "").replace(/\s+/g, " ").trim()
  if (cleaned.length <= max) return cleaned
  return `${cleaned.slice(0, max)}...`
}

function getCategoryLabel(event: EventType) {
  if (event.category === "class") return "Class"
  if (event.category === "announcement") return "Announcement"
  return "Event"
}

function isFreeEvent(event: EventType) {
  return event.pricing === "free" || event.price === 0
}

function isPublicEvent(event: EventType) {
  return event.visibility === "public" || event.isPublic === true
}

function isWorkshopEvent(event: EventType) {
  return event.activityTypes?.includes("workshop") || false
}

function isDanceEvent(event: EventType) {
  return event.activityTypes?.includes("dance") || false
}

function getPrimaryTag(event: EventType) {
  if (isFreeEvent(event)) return "Free"
  return `$${event.price ?? 0}`
}

function getTagTone(label: string) {
  if (label === "Free") return "emerald"
  if (label === "Public") return "cyan"
  if (label === "Private") return "orange"
  if (label === "Workshop") return "gold"
  if (label === "Dance") return "pink"
  return "default"
}

function getGreeting() {
  const hour = new Date().getHours()
  if (hour < 12) return "Good morning"
  if (hour < 18) return "Good afternoon"
  if (hour < 22) return "Good evening"
  return "Good night"
}

function getWeatherIcon(code: number): WeatherState["icon"] {
  if (code === 0 || code === 1) return "sun"
  if ([51, 53, 55, 61, 63, 65, 80, 81, 82].includes(code)) return "rain"
  return "cloud"
}

function getWeatherLabel(code: number) {
  if (code === 0) return "Sunny"
  if (code === 1) return "Clear"
  if (code === 2) return "Partly cloudy"
  if (code === 3) return "Cloudy"
  if ([51, 53, 55].includes(code)) return "Drizzle"
  if ([61, 63, 65, 80, 81, 82].includes(code)) return "Rain"
  return "Weather"
}

function WeatherIcon({
  icon,
  className,
}: {
  icon: WeatherState["icon"]
  className?: string
}) {
  if (icon === "sun") return <Sun className={className} />
  if (icon === "rain") return <CloudRain className={className} />
  return <Cloud className={className} />
}

function Pill({
  label,
  tone = "default",
}: {
  label: string
  tone?: "default" | "emerald" | "cyan" | "orange" | "gold" | "pink"
}) {
  const toneClass =
    tone === "emerald"
      ? "border-emerald-500/30 bg-emerald-500/12 text-emerald-400"
      : tone === "cyan"
        ? "border-cyan-500/30 bg-cyan-500/12 text-cyan-400"
        : tone === "orange"
          ? "border-orange-500/30 bg-orange-500/12 text-orange-400"
          : tone === "gold"
            ? "border-primary/30 bg-primary/12 text-primary"
            : tone === "pink"
              ? "border-pink-500/30 bg-pink-500/12 text-pink-400"
              : "border-white/10 bg-white/[0.04] text-zinc-300"

  return (
    <span
      className={`inline-flex items-center rounded-full border px-2.5 py-1 text-[10px] font-medium ${toneClass}`}
    >
      {label}
    </span>
  )
}

function DateSelector({
  date,
  setDate,
  onOpenCalendar,
}: {
  date: Date
  setDate: (date: Date) => void
  onOpenCalendar: (date: string) => void
}) {
  const prev = () => {
    const d = new Date(date)
    d.setDate(d.getDate() - 1)
    setDate(d)
  }

  const next = () => {
    const d = new Date(date)
    d.setDate(d.getDate() + 1)
    setDate(d)
  }

  return (
    <div className="flex items-center gap-1.5 rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 shadow-[0_10px_24px_rgba(0,0,0,0.18)]">
      <button
        onClick={prev}
        className="rounded-full p-1 text-zinc-400 transition-colors hover:bg-white/[0.06] hover:text-white"
      >
        <ChevronLeft className="h-4 w-4" />
      </button>

      <button
        onClick={() => onOpenCalendar(getDateString(date))}
        className="min-w-[98px] text-center text-sm font-medium text-white"
      >
        {formatDateChip(date)}
      </button>

      <button
        onClick={next}
        className="rounded-full p-1 text-zinc-400 transition-colors hover:bg-white/[0.06] hover:text-white"
      >
        <ChevronRight className="h-4 w-4" />
      </button>
    </div>
  )
}

function isMarioPlaceholderStory(story: CommunityStory, myUserId?: string | null) {
  return story.authorId === myUserId && story.id === "story-mario-placeholder"
}

function StoryRow() {
  const { user, creators, getStoriesForSource, openStory } = useApp()

  const stories = getStoriesForSource("home")

  const orderedStories = useMemo(() => {
    const myUserId = user?.id || null
    return [...stories].sort((a, b) => {
      const aIsMine = a.authorId === myUserId
      const bIsMine = b.authorId === myUserId

      if (aIsMine && !bIsMine) return -1
      if (!aIsMine && bIsMine) return 1

      const aSeen = a.seenByMe ? 1 : 0
      const bSeen = b.seenByMe ? 1 : 0

      if (aSeen !== bSeen) return aSeen - bSeen

      return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
    })
  }, [stories, user?.id])

  return (
    <div className="px-4 pt-3">
      <div className="flex gap-3.5 overflow-x-auto pb-3 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
        {orderedStories.map((story) => {
          const creator = creators.find((item) => item.id === story.authorId)
          const isMine = story.authorId === user?.id
          const isPlaceholder = isMarioPlaceholderStory(story, user?.id)

          const creatorName =
            creator?.displayName || creator?.name || creator?.username || user?.name || "Story"

          const storyLabel = isMine
            ? isPlaceholder
              ? "Your Story"
              : user?.name || "Mario"
            : creatorName

          const storyImage =
            (isMine ? user?.avatar : creator?.avatar) || story.image || "/placeholder.svg"

          const isSeen = isPlaceholder ? false : !!story.seenByMe

          const openStoryItem = () => {
            if (isPlaceholder) return
            openStory(story.id, "home")
          }

          return (
            <button
              key={story.id}
              type="button"
              onClick={openStoryItem}
              className="group flex min-w-[76px] flex-col items-center"
            >
              <div
                className={`relative flex h-[78px] w-[78px] items-center justify-center rounded-full transition-transform duration-200 group-active:scale-[0.98] ${
                  isSeen
                    ? "bg-[linear-gradient(135deg,rgba(62,62,66,0.92),rgba(34,34,36,0.92))]"
                    : "bg-[linear-gradient(135deg,rgba(214,181,83,1),rgba(155,117,22,0.88))]"
                } p-[2px]`}
              >
                <div className="relative h-full w-full overflow-hidden rounded-full bg-black">
                  <div className="absolute inset-[1px] overflow-hidden rounded-full border border-black/60 bg-[#0b0b0b]">
                    <Image
                      src={storyImage}
                      alt={storyLabel}
                      fill
                      className="object-cover"
                    />
                  </div>

                  {isMine && (
                    <div className="absolute bottom-[2px] right-[2px] z-10 flex h-5.5 w-5.5 items-center justify-center rounded-full border border-black bg-primary text-black shadow-[0_4px_10px_rgba(0,0,0,0.28)]">
                      <Plus className="h-3 w-3 stroke-[2.4]" />
                    </div>
                  )}
                </div>
              </div>

              <span
                className={`mt-2 max-w-[78px] truncate text-center text-[11px] ${
                  isMine ? "font-medium text-white" : "text-zinc-400"
                }`}
              >
                {storyLabel}
              </span>
            </button>
          )
        })}

        {orderedStories.length === 0 && (
          <div className="flex items-center rounded-full border border-white/10 bg-white/[0.03] px-4 py-3 text-[12px] text-zinc-500">
            No stories yet
          </div>
        )}
      </div>
    </div>
  )
}

