    case "music":
      return "Music"
    case "events":
      return "Events"
    case "opportunities":
      return "Opportunities"
    default:
      return "Topic"
  }
}

function getTopReaction(
  quickReactions?: Partial<Record<StoryReaction, number>>
): StoryReaction | null {
  if (!quickReactions) return null

  let topReaction: StoryReaction | null = null
  let topCount = 0

  STORY_REACTIONS.forEach((reaction) => {
    const count = quickReactions[reaction] ?? 0
    if (count > topCount) {
      topCount = count
      topReaction = reaction
    }
  })

  return topReaction
}

function StoryCard({
