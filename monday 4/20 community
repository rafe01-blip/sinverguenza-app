                  <button
                    key={post.id}
                    onClick={() => openCreatorProfile(creator.id)}
                    className="min-w-[240px] shrink-0 rounded-2xl border border-border bg-card p-4 text-left"
                  >
                    <div className="mb-2 flex items-center gap-2">
                      <div className="relative h-8 w-8 overflow-hidden rounded-full bg-muted">
                        <Image
                          src={creator.avatar || "/placeholder.svg"}
                          alt={creator.username}
                          fill
                          className="object-cover"
                        />
                      </div>
                      <div>
                        <p className="text-sm font-medium text-foreground">
                          {creator.displayName || creator.name}
                        </p>
                        <p className="text-[11px] text-muted-foreground">
                          {timeAgoFromDate(post.createdAt)}
                        </p>
                      </div>
                    </div>

                    <p className="line-clamp-3 text-sm leading-6 text-foreground">
                      {post.content}
                    </p>

                    <div className="mt-3 flex items-center gap-3 text-xs text-muted-foreground">
                      <span>{post.likes} likes</span>
                      <span>{post.comments.length} comments</span>
                      {post.spaceKey && <span>{getSpaceLabel(post.spaceKey)}</span>}
                    </div>
                  </button>
                )
              })}
            </div>
          </div>
        )}

        <div className="divide-y divide-border pt-2">
          {visibleFeedPosts.map((post) => {
            const creator = creators.find((item) => item.id === post.authorId)
            if (!creator) return null

            return (
              <article key={post.id} className="p-4">
                <div className="mb-3 flex items-start justify-between">
                  <button
                    onClick={() => openCreatorProfile(creator.id)}
                    className="flex items-center gap-3 text-left"
                  >
                    <div className="relative h-10 w-10 overflow-hidden rounded-full bg-muted">
                      <Image
                        src={creator.avatar || "/placeholder.svg"}
                        alt={creator.username}
                        fill
                        className="object-cover"
                      />
                    </div>

                    <div>
                      <div className="flex flex-wrap items-center gap-2">
                        <span className="font-medium text-foreground">
                          {creator.displayName || creator.name}
                        </span>

                        {creator.isVerified && (
                          <BadgeCheck className="h-4 w-4 shrink-0 text-primary" />
                        )}

                        <span
                          className={`rounded px-1.5 py-0.5 text-xs ${getCreatorBadgeClass(
                            String(creator.role || "member")
                          )}`}
                        >
                          {getCreatorBadgeText(String(creator.role || "member"))}
                        </span>
                      </div>

                      <div className="flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
                        <span>{timeAgoFromDate(post.createdAt)}</span>
                        <span>·</span>
                        <span>@{creator.username}</span>
                        {creator.instagramUrl && (
                          <>
                            <span>·</span>
                            <span className="inline-flex items-center gap-1">
                              <Instagram className="h-3 w-3" />
                              IG
                            </span>
                          </>
                        )}
                      </div>
                    </div>
                  </button>

                  <button className="rounded-full p-1 text-muted-foreground transition-colors hover:text-foreground">
                    <MoreHorizontal className="h-5 w-5" />
                  </button>
                </div>

                {post.spaceKey && (
                  <div className="mb-3 flex flex-wrap gap-2">
                    <button
                      onClick={() => openSpace(post.spaceKey as SpaceKey)}
                      className="rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-primary"
                    >
                      {getSpaceLabel(post.spaceKey as SpaceKey)}
                    </button>

                    {post.tags?.slice(0, 2).map((tag) => (
                      <span
                        key={`${post.id}-${tag}`}
                        className="rounded-full border border-border px-3 py-1 text-[11px] text-muted-foreground"
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                )}

                <p className="mb-3 leading-7 text-foreground">{post.content}</p>

                {post.type === "poll" && post.pollOptions && (
                  <div className="mb-3 space-y-2">
                    {post.pollOptions.map((option) => {
                      const selected = post.selectedPollOptionId === option.id

                      return (
                        <button
                          key={option.id}
                          onClick={() => voteOnPoll(post.id, option.id)}
                          disabled={!!post.selectedPollOptionId}
                          className={`flex w-full items-center justify-between rounded-2xl border px-3 py-3 transition-colors ${
                            selected
                              ? "border-primary bg-primary/10"
                              : "border-border bg-card hover:bg-secondary"
                          }`}
                        >
                          <div className="inline-flex items-center gap-2">
                            <BarChart3 className="h-4 w-4 text-primary" />
                            <span className="text-sm text-foreground">{option.text}</span>
                          </div>
                          <span className="text-xs text-muted-foreground">
                            {option.votes} votes
                          </span>
                        </button>
                      )
                    })}
                  </div>
                )}

                {post.image && (
                  <div className="relative mb-3 aspect-video overflow-hidden rounded-2xl bg-muted">
                    <Image src={post.image} alt="Post image" fill className="object-cover" />
                  </div>
                )}

                {post.instagramUrl && (
                  <a
                    href={post.instagramUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="mb-3 inline-flex items-center gap-2 text-sm text-primary hover:underline"
                  >
                    <Instagram className="h-4 w-4" />
                    Open on Instagram
                    <ExternalLink className="h-3.5 w-3.5" />
                  </a>
                )}

                <div className="flex items-center gap-6 pt-2">
                  <button
                    onClick={() => toggleCommunityLike(post.id)}
                    className="flex items-center gap-2 text-muted-foreground transition-colors hover:text-red-500"
                  >
                    <Heart
                      className={`h-5 w-5 ${post.isLiked ? "fill-red-500 text-red-500" : ""}`}
                    />
                    <span className="text-sm">{post.likes}</span>
                  </button>

                  <button
                    onClick={() => toggleComments(post.id)}
                    className="flex items-center gap-2 text-muted-foreground transition-colors hover:text-primary"
                  >
                    <MessageCircle className="h-5 w-5" />
                    <span className="text-sm">{post.comments.length}</span>
                    {post.comments.length > 0 &&
                      (expandedComments.includes(post.id) ? (
                        <ChevronUp className="h-4 w-4" />
                      ) : (
                        <ChevronDown className="h-4 w-4" />
                      ))}
                  </button>

                  <button
                    onClick={() =>
                      handleShare(`${post.content} ${post.instagramUrl || ""}`, post.instagramUrl)
                    }
                    className="flex items-center gap-2 text-muted-foreground transition-colors hover:text-primary"
                  >
                    <Share2 className="h-5 w-5" />
                  </button>
                </div>

                {expandedComments.includes(post.id) && (
                  <div className="mt-4 space-y-3 border-t border-border pt-4">
                    <div className="flex items-center gap-2">
                      <div className="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/20">
                        <span className="text-xs font-medium text-primary">
                          {user?.name?.charAt(0) || "U"}
                        </span>
                      </div>

                      <Input
                        value={commentText[post.id] || ""}
                        onChange={(e) =>
                          setCommentText((prev) => ({
                            ...prev,
                            [post.id]: e.target.value.slice(0, 120),
                          }))
                        }
                        placeholder="Write a comment..."
                        className="h-9 flex-1 text-sm"
                        onKeyDown={(e) => {
                          if (e.key === "Enter" && !e.shiftKey) {
                            e.preventDefault()
                            addCommunityComment(post.id, commentText[post.id] || "")
                            setCommentText((prev) => ({ ...prev, [post.id]: "" }))
                          }
                        }}
                      />

                      <Button
                        size="sm"
                        variant="ghost"
                        onClick={() => {
                          addCommunityComment(post.id, commentText[post.id] || "")
                          setCommentText((prev) => ({ ...prev, [post.id]: "" }))
                        }}
                        disabled={!commentText[post.id]?.trim()}
                      >
                        <Send className="h-4 w-4" />
                      </Button>
                    </div>

                    {post.comments.length === 0 ? (
                      <p className="py-2 text-center text-sm text-muted-foreground">
                        No comments yet. Be the first to comment!
                      </p>
                    ) : (
                      <div className="space-y-3">
                        {post.comments.slice(-10).map((comment) => (
                          <div key={comment.id} className="space-y-2">
                            <div className="flex items-start gap-2">
                              <div className="relative h-8 w-8 shrink-0 overflow-hidden rounded-full bg-muted">
                                <Image
                                  src={comment.authorAvatar}
                                  alt={comment.authorName}
                                  fill
                                  className="object-cover"
                                />
                              </div>

                              <div className="flex-1 rounded-2xl bg-muted/50 p-3">
                                <div className="flex items-center justify-between gap-3">
                                  <span className="text-sm font-medium text-foreground">
                                    {comment.authorName}
                                  </span>
                                  <span className="text-xs text-muted-foreground">
                                    {timeAgoFromDate(comment.createdAt)}
                                  </span>
                                </div>

                                <p className="mt-1 text-sm text-foreground">{comment.content}</p>

                                <button
                                  onClick={() =>
                                    setReplyingTo({ postId: post.id, commentId: comment.id })
                                  }
                                  className="mt-2 text-xs text-muted-foreground hover:text-primary"
                                >
                                  Reply
                                </button>
                              </div>
                            </div>

                            {replyingTo?.postId === post.id &&
                              replyingTo?.commentId === comment.id && (
                                <div className="ml-10 flex items-center gap-2">
                                  <Input
                                    value={replyText[comment.id] || ""}
                                    placeholder={`Reply to ${comment.authorName}...`}
                                    className="h-8 flex-1 text-sm"
                                    autoFocus
                                    onChange={(e) =>
                                      setReplyText((prev) => ({
                                        ...prev,
                                        [comment.id]: e.target.value.slice(0, 90),
                                      }))
                                    }
                                    onKeyDown={(e) => {
                                      if (e.key === "Enter" && !e.shiftKey) {
                                        e.preventDefault()
                                        addCommunityReply(
                                          post.id,
                                          comment.id,
                                          replyText[comment.id] || ""
                                        )
                                        setReplyText((prev) => ({
                                          ...prev,
                                          [comment.id]: "",
                                        }))
                                        setReplyingTo(null)
                                      }

                                      if (e.key === "Escape") {
                                        setReplyingTo(null)
                                      }
                                    }}
                                  />

                                  <Button
                                    size="sm"
                                    variant="ghost"
                                    onClick={() => {
                                      addCommunityReply(
                                        post.id,
                                        comment.id,
                                        replyText[comment.id] || ""
                                      )
                                      setReplyText((prev) => ({
                                        ...prev,
                                        [comment.id]: "",
                                      }))
                                      setReplyingTo(null)
                                    }}
                                  >
                                    <Send className="h-4 w-4" />
                                  </Button>
                                </div>
                              )}

                            {comment.replies.length > 0 && (
                              <div className="ml-10 space-y-2">
                                {comment.replies.map((reply) => (
                                  <div key={reply.id} className="flex items-start gap-2">
                                    <div className="relative h-6 w-6 shrink-0 overflow-hidden rounded-full bg-muted">
                                      <Image
                                        src={reply.authorAvatar}
                                        alt={reply.authorName}
                                        fill
                                        className="object-cover"
                                      />
                                    </div>

                                    <div className="flex-1 rounded-2xl bg-muted/30 p-2.5">
                                      <div className="flex items-center justify-between gap-3">
                                        <span className="text-xs font-medium text-foreground">
                                          {reply.authorName}
                                        </span>
                                        <span className="text-xs text-muted-foreground">
                                          {timeAgoFromDate(reply.createdAt)}
                                        </span>
                                      </div>

                                      <p className="mt-1 text-xs text-foreground">{reply.content}</p>
                                    </div>
                                  </div>
                                ))}
                              </div>
                            )}
                          </div>
                        ))}
                      </div>
                    )}

                    {post.comments.length >= 10 && (
                      <p className="text-center text-xs text-muted-foreground">
                        Showing last 10 comments
                      </p>
                    )}
                  </div>
                )}
              </article>
            )
          })}
        </div>
      </div>

      <BottomNav />
    </div>
  )
}