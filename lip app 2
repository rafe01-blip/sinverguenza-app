        },
      }
    })
  }

  const setProducts = (nextProducts: ProductType[]) => {
    setProductsState(nextProducts.map((product, index) => normalizeProduct(product, index)))
  }

  const setCreators = (nextCreators: Creator[]) => {
    setCreatorsState(nextCreators.map(normalizeCreator))
  }

  const setSelectedCreator = (creator: Creator | null) => {
    setSelectedCreatorState(creator ? normalizeCreator(creator) : null)
  }

  const navigateTo = (screen: Screen) => {
    setCurrentScreen(screen)
  }

  const goBack = () => {
    if (currentScreen === "checkout") {
      setCurrentScreen("cart")
      return
    }

    if (currentScreen === "cart") {
      setCurrentScreen("shop")
      return
    }

    if (currentScreen === "product-detail") {
      setCurrentScreen("shop")
      return
    }

    if (currentScreen === "story-viewer") {
      setCurrentScreen("community")
      return
    }

    if (currentScreen === "creator-profile" || currentScreen === "creator-list") {
      setCurrentScreen("community")
      return
    }

    if (currentScreen === "space") {
      setCurrentScreen("community")
      return
    }

    if (currentScreen === "event-detail") {
      if (lastEventSource === "home") {
        setCurrentScreen("home")
        return
      }

      if (lastEventSource === "calendar") {
        setCurrentScreen("calendar")
        return
      }

      setCurrentScreen("community")
      return
    }

    if (currentScreen === "settings") {
      setCurrentScreen("profile")
      return
    }

    setCurrentScreen("home")
  }

  const createEvent = (event: EventType) => {
    const normalizedEvent: EventType = {
      ...event,
      likes: event.likes ?? 0,
      commentsCount: event.commentsCount ?? 0,
      comments: normalizeComments(event.comments),
      isLiked: event.isLiked ?? false,
      isSaved: event.isSaved ?? false,
      isFree: event.isFree ?? (event.pricing === "free" || event.price === 0),
      visibility: event.visibility ?? "public",
      pricing: event.pricing ?? "free",
      price: event.price ?? 0,
      paymentMethod: event.paymentMethod ?? null,
      paymentValue: event.paymentValue ?? "",
      zelleContact: event.zelleContact ?? "",
      activityTypes: event.activityTypes ?? [],
      images: event.images ?? (event.image ? [event.image] : []),
      status: event.status ?? "upcoming",
    }

    setEvents((prev) => [normalizedEvent, ...prev])
  }

  const toggleLike = (eventId: string) => {
    setEvents((prev) =>
      prev.map((event) =>
        event.id === eventId
          ? {
              ...event,
              isLiked: !event.isLiked,
              likes: (event.likes ?? 0) + (event.isLiked ? -1 : 1),
            }
          : event
      )
    )

    setSelectedEvent((prev) =>
      prev && prev.id === eventId
        ? {
            ...prev,
            isLiked: !prev.isLiked,
            likes: (prev.likes ?? 0) + (prev.isLiked ? -1 : 1),
          }
        : prev
    )
  }

  const toggleSave = (eventId: string) => {
    setEvents((prev) =>
      prev.map((event) =>
        event.id === eventId
          ? {
              ...event,
              isSaved: !event.isSaved,
            }
          : event
      )
    )

    setSelectedEvent((prev) =>
      prev && prev.id === eventId
        ? {
            ...prev,
            isSaved: !prev.isSaved,
          }
        : prev
    )
  }

  const addComment = (eventId: string, text: string) => {
    const trimmed = text.trim()
    if (!trimmed) return

    const newComment: EventComment = {
      id: `comment-${Date.now()}`,
      userName: user?.name || "Prototype",
      text: trimmed,
      createdAt: new Date().toISOString(),
      replies: [],
    }

    setEvents((prev) =>
      prev.map((event) =>
        event.id === eventId
          ? {
              ...event,
              comments: [...normalizeComments(event.comments), newComment],
              commentsCount: (event.commentsCount ?? 0) + 1,
            }
          : event
      )
    )

    setSelectedEvent((prev) =>
      prev && prev.id === eventId
        ? {
            ...prev,
            comments: [...normalizeComments(prev.comments), newComment],
            commentsCount: (prev.commentsCount ?? 0) + 1,
          }
        : prev
    )
  }

  const addReplyToComment = (eventId: string, commentId: string, text: string) => {
    const trimmed = text.trim()
    if (!trimmed) return

    const newReply: EventCommentReply = {
      id: `reply-${Date.now()}`,
      userName: user?.name || "Prototype",
      text: trimmed,
      createdAt: new Date().toISOString(),
    }

    const applyReply = (event: EventType) => {
      const updatedComments = normalizeComments(event.comments).map((comment) =>
        comment.id === commentId
          ? {
              ...comment,
              replies: [...(comment.replies ?? []), newReply],
            }
          : comment
      )

      return {
        ...event,
        comments: updatedComments,
      }
    }

    setEvents((prev) => prev.map((event) => (event.id === eventId ? applyReply(event) : event)))
    setSelectedEvent((prev) => (prev && prev.id === eventId ? applyReply(prev) : prev))
  }

  const openCreatorProfile = (creatorId: string) => {
    const creator = creators.find((item) => item.id === creatorId)
    if (!creator) return
    setSelectedCreatorState(creator)
    setCurrentScreen("creator-profile")
  }

  const toggleFollow = (id: string) => {
    setCreatorsState((prev) =>
      prev.map((creator) => {
        if (creator.id !== id) return creator

        const nextFollowing = !creator.isFollowing
        const followersCount = creator.followersCount ?? creator.followers ?? 0

        return {
          ...creator,
          isFollowing: nextFollowing,
          followersCount: nextFollowing ? followersCount + 1 : Math.max(0, followersCount - 1),
          followers: nextFollowing ? followersCount + 1 : Math.max(0, followersCount - 1),
        }
      })
    )

    setSelectedCreatorState((prev) => {
      if (!prev || prev.id !== id) return prev
      const nextFollowing = !prev.isFollowing
      const followersCount = prev.followersCount ?? prev.followers ?? 0

      return {
        ...prev,
        isFollowing: nextFollowing,
        followersCount: nextFollowing ? followersCount + 1 : Math.max(0, followersCount - 1),
        followers: nextFollowing ? followersCount + 1 : Math.max(0, followersCount - 1),
      }
    })
  }

  const addToCart = ({
    product,
    size,
    color,
    quantity,
  }: {
    product: ProductType
    size: string
    color: string
    quantity: number
  }) => {
    setCartItems((prev) => {
      const existingItem = prev.find(
        (item) => item.productId === product.id && item.size === size && item.color === color
      )

      if (existingItem) {
        return prev.map((item) =>
          item.id === existingItem.id
            ? {
                ...item,
                quantity: item.quantity + quantity,
              }
            : item
        )
      }

      return [
        ...prev,
        {
          id: `cart-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`,
          productId: product.id,
          productName: product.name,
          productImage: product.images?.[0] || product.image || "/placeholder.svg",
          size,
          color,
          quantity,
          price: product.price,
        },
      ]
    })
  }

  const removeFromCart = (id: string) => {
    setCartItems((prev) => prev.filter((item) => item.id !== id))
  }

  const updateCartQuantity = (id: string, qty: number) => {
    if (qty <= 0) {
      removeFromCart(id)
      return
    }

    setCartItems((prev) =>
      prev.map((item) => (item.id === id ? { ...item, quantity: qty } : item))
    )
  }

  const clearCart = () => {
    setCartItems([])
  }

  const createCommunityPost = (input: CreateCommunityPostInput) => {
    const trimmed = input.content.trim()
    if (!trimmed) return

    if (input.type === "story" || input.type === "video") {
      const newStory: CommunityStory = {
        id: `story-${Date.now()}`,
        authorId: user?.id || "me-user",
        type: input.type,
        content: trimmed,
        image: input.image,
        createdAt: new Date().toISOString(),
        expiresAt: new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString(),
        instagramUrl: input.instagramUrl,
        storyViewMode: input.storyViewMode || "internal",
      }

      setCommunityStories((prev) => [newStory, ...prev])
      return
    }

    const newPost: CommunityPost = {
      id: `community-post-${Date.now()}`,
      authorId: user?.id || "me-user",
      type: input.type === "poll" ? "poll" : "post",
      content: trimmed,
      image: input.image,
      createdAt: new Date().toISOString(),
      likes: 0,
      isLiked: false,
      instagramUrl: input.instagramUrl,
      comments: [],
      spaceKey: input.spaceKey ?? activeSpace ?? null,
      tags: input.spaceKey || activeSpace ? [String(input.spaceKey ?? activeSpace)] : [],
      pollOptions:
        input.type === "poll"
          ? (input.pollOptions || []).slice(0, 4).map((option, index) => ({
              id: `poll-option-${Date.now()}-${index}`,
              text: option,
              votes: 0,
            }))
          : undefined,
    }

    setCommunityPosts((prev) => [newPost, ...prev])

    setCreatorsState((prev) =>
      prev.map((creator) =>
        creator.id === (user?.id || "me-user")
          ? {
              ...creator,
              postsCount: (creator.postsCount ?? creator.posts ?? 0) + 1,
              posts: (creator.posts ?? creator.postsCount ?? 0) + 1,
            }
          : creator
      )
    )

    if (newPost.spaceKey) {
      setSpaces((prev) =>
        prev.map((space) =>
          space.key === newPost.spaceKey
            ? { ...space, topicsCount: space.topicsCount + 1 }
            : space
        )
      )
    }
  }

  const toggleCommunityLike = (postId: string) => {
    setCommunityPosts((prev) =>
      prev.map((post) =>
        post.id === postId
          ? {
              ...post,
              isLiked: !post.isLiked,
              likes: post.isLiked ? Math.max(0, post.likes - 1) : post.likes + 1,
            }
          : post
      )
    )
  }

  const addCommunityComment = (postId: string, text: string) => {
    const trimmed = text.trim()
    if (!trimmed) return

    const newComment: CommunityComment = {
      id: `community-comment-${Date.now()}`,
      authorId: user?.id || "me-user",
      authorName: user?.name || "You",
      authorAvatar: user?.avatar || "/placeholder.svg",
      content: trimmed,
      createdAt: new Date().toISOString(),
      replies: [],
    }

    setCommunityPosts((prev) =>
      prev.map((post) =>
        post.id === postId
          ? {
              ...post,
              comments:
                post.comments.length >= 10
                  ? [...post.comments.slice(1), newComment]
                  : [...post.comments, newComment],
            }
          : post
      )
    )
  }

  const addCommunityReply = (postId: string, commentId: string, text: string) => {
    const trimmed = text.trim()
    if (!trimmed) return

    const newReply: CommunityReply = {
      id: `community-reply-${Date.now()}`,
      authorId: user?.id || "me-user",
      authorName: user?.name || "You",
      authorAvatar: user?.avatar || "/placeholder.svg",
      content: trimmed,
      createdAt: new Date().toISOString(),
    }

    setCommunityPosts((prev) =>
      prev.map((post) =>
        post.id === postId
          ? {
              ...post,
              comments: post.comments.map((comment) =>
                comment.id === commentId
                  ? {
                      ...comment,
                      replies: [...comment.replies, newReply],
                    }
                  : comment
              ),
            }
          : post
      )
    )
  }

  const voteOnPoll = (postId: string, optionId: string) => {
    setCommunityPosts((prev) =>
      prev.map((post) => {
        if (post.id !== postId || post.type !== "poll" || !post.pollOptions) return post
        if (post.selectedPollOptionId) return post

        return {
          ...post,
          selectedPollOptionId: optionId,
          pollOptions: post.pollOptions.map((option) =>
            option.id === optionId ? { ...option, votes: option.votes + 1 } : option
          ),
        }
      })
    )
  }

  const openStory = (storyId: string) => {
    setSelectedStoryId(storyId)
    setCurrentScreen("story-viewer")
  }

  const openSpace = (space: SpaceKey) => {
    setActiveSpace(space)
    setCurrentScreen("space")
  }

  const toggleJoinSpace = (space: SpaceKey) => {
    setSpaces((prev) =>
      prev.map((item) =>
        item.key === space
          ? {
              ...item,
              isJoined: !item.isJoined,
              membersCount: item.isJoined
                ? Math.max(0, item.membersCount - 1)
                : item.membersCount + 1,
            }
          : item
      )
    )
  }

  const getSpacePosts = (space: SpaceKey | null) => {
    if (!space) return communityPosts
    return communityPosts.filter((post) => post.spaceKey === space)
  }

  const getTopCreators = () => {
    return [...creators]
      .sort((a, b) => {
        const aScore = (a.followersCount ?? 0) + (a.totalLikes ?? 0) * 0.1
        const bScore = (b.followersCount ?? 0) + (b.totalLikes ?? 0) * 0.1
        return bScore - aScore
      })
      .slice(0, 10)
  }

  const getCreatorFollowers = (creatorId: string) => {
    const target = creators.find((item) => item.id === creatorId)
    if (!target) return []
    return creators.filter((item) => item.id !== creatorId).slice(0, Math.min(8, creators.length))
  }

  const getCreatorFollowing = (creatorId: string) => {
    const target = creators.find((item) => item.id === creatorId)
    if (!target) return []
    return creators.filter((item) => item.id !== creatorId).reverse().slice(0, Math.min(8, creators.length))
  }

  const getCreatorEvents = (creatorId: string) => {
    return events.filter(
      (event) =>
        event.organizerCreatorId === creatorId ||
        event.hostUsername === creators.find((c) => c.id === creatorId)?.username
    )
  }

  const openCreatorList = (
    type: CreatorListType,
    creatorId?: string | null,
    title?: string
  ) => {
    setCreatorListType(type)
    setCreatorListTitle(title || "Top Creators")
    setCreatorListSourceCreatorId(creatorId || null)

    if (creatorId) {
      const creator = creators.find((item) => item.id === creatorId)
      if (creator) {
        setSelectedCreatorState(creator)
      }
    }

    setCurrentScreen("creator-list")
  }

  const cartSubtotal = useMemo(
    () => cartItems.reduce((sum, item) => sum + item.price * item.quantity, 0),
    [cartItems]
  )

  const cartShipping = cartItems.length > 0 && cartSubtotal < 75 ? 8 : 0
  const cartTotal = cartSubtotal + cartShipping

  return (
    <AppContext.Provider
      value={{
        currentScreen,
        setCurrentScreen,
        goBack,

        user,
        setUser,
        updateMyProfile,
        updateMySocials,

        homeSelectedDate,
        setHomeSelectedDate,

        events,
        selectedEvent,
        setSelectedEvent,
        lastEventSource,
        setLastEventSource,
        createEvent,
        toggleLike,
        toggleSave,
        addComment,
        addReplyToComment,
        openCreatorProfile,

        calendarSearchOpen,
        setCalendarSearchOpen,
        calendarSearchQuery,
        setCalendarSearchQuery,

        selectedDate,
        setSelectedDate,
        currentMonth,
        setCurrentMonth,
        calendarFilters,
        setCalendarFilters,

        products,
        setProducts,
        selectedProduct,
        setSelectedProduct,

        cartItems,
        addToCart,
        removeFromCart,
        updateCartQuantity,
        clearCart,
        cartSubtotal,
        cartShipping,
        cartTotal,

        creators,
        setCreators,
        selectedCreator,
        setSelectedCreator,
        toggleFollow,

        communityPosts,
        communityStories,
        createCommunityPost,
        toggleCommunityLike,
        addCommunityComment,
        addCommunityReply,
        voteOnPoll,

        spaces,
        activeSpace,
        setActiveSpace,
        openSpace,
        toggleJoinSpace,
        getSpacePosts,

        selectedStoryId,
        setSelectedStoryId,
        openStory,

        creatorListType,
        creatorListTitle,
        openCreatorList,
        getTopCreators,
        getCreatorFollowers,
        getCreatorFollowing,
        getCreatorEvents,

        navigateTo,
      }}
    >
      {children}
    </AppContext.Provider>
  )
}

export const useApp = () => {
  const context = useContext(AppContext)
  if (!context) {
    throw new Error("useApp must be used inside AppProvider")
  }
  return context
}