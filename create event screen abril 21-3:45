function normalizeDate(raw: string) {
  const text = raw.trim()

  const iso = text.match(/\b(20\d{2})-(\d{2})-(\d{2})\b/)
  if (iso) return iso[0]

  const mdY = text.match(/\b(\d{1,2})\/(\d{1,2})\/(20\d{2})\b/)
  if (mdY) {
    const mm = mdY[1].padStart(2, "0")
    const dd = mdY[2].padStart(2, "0")
    return `${mdY[3]}-${mm}-${dd}`
  }

  const monthNames = [
    "january","february","march","april","may","june",
    "july","august","september","october","november","december",
  ]

  const lower = text.toLowerCase()
  for (let i = 0; i < monthNames.length; i++) {
    const month = monthNames[i]
    const regex = new RegExp(`${month}\\s+(\\d{1,2})(?:,)?\\s+(20\\d{2})`)
    const match = lower.match(regex)
    if (match) {
      const mm = String(i + 1).padStart(2, "0")
      const dd = String(Number(match[1])).padStart(2, "0")
      return `${match[2]}-${mm}-${dd}`
    }
  }

  return ""
}

function normalizeTime(raw: string) {
  const text = raw.trim().toLowerCase()

  const direct24 = text.match(/\b([01]?\d|2[0-3]):([0-5]\d)\b/)
  if (direct24) {
    return `${direct24[1].padStart(2, "0")}:${direct24[2]}`
  }

  const ampm = text.match(/\b(\d{1,2})(?::(\d{2}))?\s*(am|pm)\b/)
  if (ampm) {
    let hour = Number(ampm[1])
    const minute = ampm[2] || "00"
    const period = ampm[3]

    if (period === "pm" && hour !== 12) hour += 12
    if (period === "am" && hour === 12) hour = 0

    return `${String(hour).padStart(2, "0")}:${minute}`
  }

  return ""
}
function extractInstagramValue(text: string) {
  const urlMatch = text.match(/https?:\/\/(www\.)?instagram\.com\/[^\s]+/i)
  if (urlMatch) return urlMatch[0]

  const handleMatch = text.match(/@([a-z0-9._]+)/i)
  if (handleMatch) return handleMatch[0]

  return ""
}

function extractOnlineLink(text: string) {
  const directUrl = text.match(/https?:\/\/[^\s]+/i)
  if (directUrl) return directUrl[0]

  const zoomLine = text.match(/(zoom|meet|google meet|teams)[:\-]?\s*([^\n]+)/i)
  if (zoomLine) return zoomLine[2].trim()

  return ""
}

function extractPhoneNumber(text: string) {
  const explicit =
    text.match(/(phone number|phone|contact number|contact|whatsapp)[:\-]?\s*([^\n]+)/i)?.[2] ||
    ""

  if (explicit) return explicit.trim()

  const generic = text.match(/(\+?\d[\d\s().-]{7,}\d)/)
  if (generic) return generic[1].trim()

  return ""
}

function labelFromActivitySlug(slug: string) {
  const found = ACTIVITY_OPTIONS.find((item) => item.slug === slug)
  return found ? found.label : slug
}

function formatAgeRuleLabel(value: string) {
  if (value === "family") return "Family Friendly"
  return value
}
function parseFlyerText(text: string) {
  const clean = text.replace(/\r/g, "").trim()
  const lines = clean
    .split("\n")
    .map((line) => line.trim())
    .filter(Boolean)

  const lower = clean.toLowerCase()

  const title =
    lines[0]?.slice(0, 90) ||
    clean.match(/title[:\-]?\s*(.+)/i)?.[1]?.split("\n")[0]?.slice(0, 90) ||
    ""

  const dateMatch =
    clean.match(/date[:\-]?\s*(.+)/i)?.[1]?.split("\n")[0] ||
    clean.match(
      /\b(?:january|february|march|april|may|june|july|august|september|october|november|december)\s+\d{1,2}(?:,)?\s+20\d{2}\b/i
    )?.[0] ||
    clean.match(/\b\d{1,2}\/\d{1,2}\/20\d{2}\b/)?.[0] ||
    ""

  const timeMatches = clean.match(/\b\d{1,2}(?::\d{2})?\s*(?:AM|PM|am|pm)\b/g) || []
  const direct24Matches = clean.match(/\b([01]?\d|2[0-3]):[0-5]\d\b/g) || []

  const firstTime =
    clean.match(/time[:\-]?\s*(.+)/i)?.[1]?.split("\n")[0] ||
    timeMatches[0] ||
    direct24Matches[0] ||
    ""

  const secondTime = timeMatches[1] || direct24Matches[1] || ""

  const locationMatch =
    clean.match(/location[:\-]?\s*(.+)/i)?.[1]?.split("\n")[0] ||
    clean.match(/address[:\-]?\s*(.+)/i)?.[1]?.split("\n")[0] ||
    ""

  const priceMatch = clean.match(/\$\s?(\d+(?:\.\d{1,2})?)/)?.[1] || ""
  const zelleMatch = clean.match(/zelle[:\-]?\s*(.+)/i)?.[1]?.split("\n")[0] || ""

  const category: EventType["category"] = lower.includes("announcement")
    ? "announcement"
    : lower.includes("class")
    ? "class"
    : "event"

  const type = lower.includes("private") ? "private" : "public"
  const isFree = lower.includes("free") || !priceMatch

  const activityTypes: string[] = []
  if (lower.includes("workshop")) activityTypes.push("workshop")
  if (lower.includes("off campus")) activityTypes.push("off-campus")
  if (lower.includes("individual")) activityTypes.push("individual")
  if (
    lower.includes("dance") ||
    lower.includes("salsa") ||
    lower.includes("bachata") ||
    lower.includes("merengue")
  ) {
    activityTypes.push("dance")
  }

  let ageRule: "family" | "18+" | "21+" = "family"
  if (lower.includes("21+")) ageRule = "21+"
  else if (lower.includes("18+")) ageRule = "18+"

  const onlineLink = extractOnlineLink(clean)
  const phoneNumber = extractPhoneNumber(clean)

  return {
    title,
    description: clean.slice(0, 700),
    date: normalizeDate(dateMatch),
    time: normalizeTime(firstTime),
    endTime: normalizeTime(secondTime),
    location: locationMatch.slice(0, 120),
    price: priceMatch,
    zelleContact: zelleMatch,
    category,
    type,
    isFree,
    instagram: extractInstagramValue(clean),
    activityTypes,
    ageRule,
    onlineLink,
    phoneNumber,
  }
}
