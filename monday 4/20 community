            alt={story.content}
            fill
            className="object-cover transition-transform duration-300 group-hover:scale-[1.02]"
          />
          <div className="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-black/10" />
          <div className="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(201,168,76,0.16),transparent_28%)]" />

          <div className="absolute left-3 top-3 right-3 flex items-start justify-between gap-3">
            <div className="flex items-center gap-2">
              <div className="relative h-9 w-9 overflow-hidden rounded-full border border-white/40 bg-muted">
                <Image
                  src={creator.avatar || "/placeholder.svg"}
                  alt={creator.username}
                  fill
                  className="object-cover"
                />
              </div>

              <div className="min-w-0">
                <p className="truncate text-[12px] font-semibold text-white">
                  {creator.displayName || creator.name}
                </p>
                <p className="truncate text-[11px] text-white/70">@{creator.username}</p>
              </div>
            </div>

            <div className="rounded-full border border-primary/30 bg-black/55 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-primary backdrop-blur-md">
              24h
            </div>
