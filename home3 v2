export function HomeScreen() {
  const { events, user } = useApp()

  const [date, setDate] = useState(new Date())
  const [filtersOpen, setFiltersOpen] = useState(false)
  const [selectedFilters, setSelectedFilters] = useState<FilterKey[]>([])

  const today = getDateString(new Date())

  const demoEvents: EventType[] = [
    {
      id: "demo-1",
      title: "Bachata Fundamentals",
      date: today,
      time: "18:00",
      location: "Studio A",
      image: "/placeholder.svg",
      description: "Learn bachata basics in a comfortable and welcoming class for all levels.",
      likes: 28,
      commentsCount: 0,
      hostName: "Maria",
      category: "class",
      visibility: "public",
      pricing: "free",
      price: 0,
      comments: [],
      isLiked: false,
      isSaved: false,
      activityTypes: ["dance"],
    },
    {
      id: "demo-2",
      title: "Advanced Salsa",
      date: today,
      time: "19:30",
      location: "Studio B",
      image: "/placeholder.svg",
      description: "Sharpen timing, technique, and partner work with a more advanced salsa session.",
      likes: 34,
      commentsCount: 0,
      hostName: "Diego",
      category: "class",
      visibility: "public",
      pricing: "paid",
      price: 20,
      comments: [],
      isLiked: false,
      isSaved: false,
      activityTypes: ["dance", "workshop"],
    },
    {
      id: "demo-3",
      title: "Latin Festival",
      date: today,
      time: "21:00",
      location: "NYC",
      image: "/placeholder.svg",
      description: "A lively community festival with music, social dancing, and a vibrant atmosphere.",
      likes: 120,
      commentsCount: 0,
      hostName: "Ana",
      category: "event",
      visibility: "public",
      pricing: "paid",
      price: 25,
      comments: [],
      isLiked: false,
      isSaved: false,
      activityTypes: ["dance", "off-campus"],
    },
  ]

  const sourceEvents = events.length > 0 ? events : demoEvents

  const toggleFilter = (filter: FilterKey) => {
    setSelectedFilters((prev) =>
      prev.includes(filter)
        ? prev.filter((item) => item !== filter)
        : [...prev, filter]
    )
  }

  const clearFilters = () => setSelectedFilters([])

  const filteredEvents = useMemo(() => {
    let result = sourceEvents.filter((e) => e.date === getDateString(date))

    if (selectedFilters.length === 0) return result

    return result.filter((event) =>
      selectedFilters.every((filter) => {
        switch (filter) {
          case "public":
            return event.visibility === "public" || event.isPublic === true
          case "private":
            return event.visibility === "private" || event.isPublic === false
          case "free":
            return event.pricing === "free" || event.price === 0
          case "paid":
            return event.pricing === "paid" || (event.price ?? 0) > 0
          case "offCampus":
            return event.activityTypes?.includes("off-campus") || false
          case "workshop":
            return event.activityTypes?.includes("workshop") || false
          case "individual":
            return event.activityTypes?.includes("individual") || false
          case "dance":
            return event.activityTypes?.includes("dance") || false
          default:
            return true
        }
      })
    )
  }, [sourceEvents, date, selectedFilters])

  const userName = user?.name?.split(" ")[0] || "Mario"

  return (
    <div className="flex h-screen flex-col bg-background">
      <TopHeader title="Home" showProfile />

      <div className="flex-1 overflow-y-auto pb-28">
        <StoryRow />

        <HeroStrip userName={userName} />

        <div className="sticky top-0 z-20 mt-4 border-y border-white/5 bg-background/92 px-4 py-3 backdrop-blur-md">
          <div className="flex items-center justify-between gap-3">
            <button
              onClick={() => setFiltersOpen((prev) => !prev)}
              className={`flex items-center gap-2 rounded-full border px-3.5 py-2 text-sm shadow-[0_10px_20px_rgba(0,0,0,0.14)] transition-all ${
                filtersOpen || selectedFilters.length > 0
                  ? "border-primary/30 bg-primary/10 text-primary"
                  : "border-white/10 bg-white/[0.04] text-white"
              }`}
            >
              <SlidersHorizontal className="h-4 w-4" />
              Filter {selectedFilters.length > 0 ? `(${selectedFilters.length})` : ""}
            </button>

            <DateSelector date={date} setDate={setDate} />
          </div>

          <div
            className={`grid transition-all duration-300 ease-out ${
              filtersOpen
                ? "mt-4 grid-rows-[1fr] opacity-100"
                : "mt-0 grid-rows-[0fr] opacity-0"
            }`}
          >
            <div className="overflow-hidden">
              <div className="flex flex-wrap gap-2">
                {FILTER_OPTIONS.map((filter) => {
                  const active = selectedFilters.includes(filter.key)

                  return (
                    <button
                      key={filter.key}
                      onClick={() => toggleFilter(filter.key)}
                      className={`rounded-full border px-2.5 py-1.5 text-[11px] font-medium transition-all ${
                        active
                          ? "border-primary bg-primary/15 text-primary"
                          : "border-white/10 bg-white/[0.04] text-zinc-300"
                      }`}
                    >
                      {filter.label}
                    </button>
                  )
                })}

                {selectedFilters.length > 0 && (
                  <button
                    onClick={clearFilters}
                    className="rounded-full border border-white/10 bg-white/[0.04] px-2.5 py-1.5 text-[11px] font-medium text-zinc-400 transition-all"
                  >
                    Clear
                  </button>
                )}
              </div>
            </div>
          </div>
        </div>

        <div className="space-y-4 px-4 pb-2 pt-4">
          {filteredEvents.map((event, index) => (
            <EventCard key={event.id} event={event} index={index} />
          ))}

          {filteredEvents.length === 0 && (
            <div className="rounded-[24px] border border-white/10 bg-white/[0.03] px-5 py-12 text-center text-muted-foreground">
              No events for this filter/date
            </div>
          )}
        </div>
      </div>

      <BottomNav />

      <style jsx global>{`
        @keyframes homeCardIn {
          0% {
            opacity: 0;
            transform: translateY(10px);
          }
          100% {
            opacity: 1;
            transform: translateY(0);
          }
        }
      `}</style>
    </div>
  )
}

